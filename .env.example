# LLM Provider — choose one: anthropic, openai, ollama
LLM_PROVIDER=anthropic
LLM_MODEL=claude-haiku-4-5-20251001

# Required for LLM_PROVIDER=anthropic
ANTHROPIC_API_KEY=sk-ant-api03-...

# Required for LLM_PROVIDER=openai (e.g. Apertus)
# LLM_BASE_URL=https://api.apertus.ch/v1
# LLM_API_KEY=your-key-here

# Optional — SRG news API (pending approval)
SRGSSR_CLIENT_ID=
SRGSSR_CLIENT_SECRET=

# Let's Encrypt contact email (Traefik ACME registration)
ACME_EMAIL=sali@buenzli.space

# Contact form → SMTP (Infomaniak mailbox auth)
# If SMTP_HOST is unset, /contact submissions are logged only.
SMTP_HOST=mail.infomaniak.com
SMTP_PORT=465
SMTP_USER=sali@buenzli.space
SMTP_PASS=
SMTP_FROM=sali@buenzli.space
SMTP_TO=sali@buenzli.space
