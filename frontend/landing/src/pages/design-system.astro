---
import Button from '../components/ui/Button.astro';
import Badge from '../components/ui/Badge.astro';
import Card from '../components/ui/Card.astro';
import Pill from '../components/ui/Pill.astro';
import SectionHeader from '../components/ui/SectionHeader.astro';
import '../styles/global.css';
---

<!doctype html>
<html lang="en" class="scroll-smooth">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Bünzli Design System</title>
  <meta name="robots" content="noindex, nofollow" />
  <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
</head>
<body class="bg-zh-black-5 font-sans text-zurich-dark">

  <!-- Header -->
  <div class="bg-zurich-navy text-white px-8 py-10 mb-12">
    <div class="max-w-5xl mx-auto">
      <div class="flex items-center gap-3 mb-3">
        <img src="/zh-lion.svg" alt="" aria-hidden="true" class="w-8 h-8 brightness-0 invert opacity-80" />
        <span class="font-bold text-2xl">bünzli<span class="text-white/40">.</span> design system</span>
      </div>
      <p class="text-white/50 text-sm font-mono">Inspired by zh.ch · v1.0 · Internal reference</p>
    </div>
  </div>

  <div class="max-w-5xl mx-auto px-8 pb-24 space-y-20">

    <!-- ── Colors ─────────────────────────────────────────────────── -->
    <section>
      <h2 class="text-xl font-bold mb-1">Colors</h2>
      <p class="text-sm text-zurich-gray mb-8">Brand palette + ZH canton gray scale</p>

      <div class="space-y-6">
        <!-- Brand blues -->
        <div>
          <p class="text-xs font-mono text-zurich-gray uppercase tracking-wider mb-3">Brand — Zürich Blue</p>
          <div class="flex gap-3 flex-wrap">
            <div class="text-center">
              <div class="w-16 h-16 rounded-xl bg-zurich-blue mb-2"></div>
              <p class="text-[10px] font-mono text-zurich-gray">blue</p>
              <p class="text-[10px] font-mono text-zurich-gray">#0070B4</p>
            </div>
            <div class="text-center">
              <div class="w-16 h-16 rounded-xl bg-zurich-blue-dark mb-2"></div>
              <p class="text-[10px] font-mono text-zurich-gray">blue-dark</p>
              <p class="text-[10px] font-mono text-zurich-gray">#00407C</p>
            </div>
            <div class="text-center">
              <div class="w-16 h-16 rounded-xl bg-zurich-blue-light border border-zurich-border mb-2"></div>
              <p class="text-[10px] font-mono text-zurich-gray">blue-light</p>
              <p class="text-[10px] font-mono text-zurich-gray">#EDF5FA</p>
            </div>
            <div class="text-center">
              <div class="w-16 h-16 rounded-xl bg-zurich-navy mb-2"></div>
              <p class="text-[10px] font-mono text-zurich-gray">navy</p>
              <p class="text-[10px] font-mono text-zurich-gray">#08111F</p>
            </div>
          </div>
        </div>

        <!-- Accent colors -->
        <div>
          <p class="text-xs font-mono text-zurich-gray uppercase tracking-wider mb-3">Accents</p>
          <div class="flex gap-3 flex-wrap">
            <div class="text-center">
              <div class="w-16 h-16 rounded-xl bg-badi-orange mb-2"></div>
              <p class="text-[10px] font-mono text-zurich-gray">badi-orange</p>
              <p class="text-[10px] font-mono text-zurich-gray">#F26522</p>
            </div>
            <div class="text-center">
              <div class="w-16 h-16 rounded-xl bg-tram-green mb-2"></div>
              <p class="text-[10px] font-mono text-zurich-gray">tram-green</p>
              <p class="text-[10px] font-mono text-zurich-gray">#3D8A3E</p>
            </div>
            <div class="text-center">
              <div class="w-16 h-16 rounded-xl mb-2" style="background:#1A7F1F"></div>
              <p class="text-[10px] font-mono text-zurich-gray">zh-success</p>
              <p class="text-[10px] font-mono text-zurich-gray">#1A7F1F</p>
            </div>
            <div class="text-center">
              <div class="w-16 h-16 rounded-xl mb-2" style="background:#D93C1A"></div>
              <p class="text-[10px] font-mono text-zurich-gray">zh-error</p>
              <p class="text-[10px] font-mono text-zurich-gray">#D93C1A</p>
            </div>
          </div>
        </div>

        <!-- ZH Gray scale -->
        <div>
          <p class="text-xs font-mono text-zurich-gray uppercase tracking-wider mb-3">ZH Gray Scale (zh-black-*)</p>
          <div class="flex gap-2 flex-wrap">
            {[
              { name: '100', hex: '#000000' },
              { name: '90',  hex: '#1A1A1A' },
              { name: '80',  hex: '#333333' },
              { name: '60',  hex: '#666666' },
              { name: '40',  hex: '#999999' },
              { name: '20',  hex: '#CCCCCC' },
              { name: '10',  hex: '#E5E5E5' },
              { name: '5',   hex: '#F7F7F7' },
            ].map(s => (
              <div class="text-center">
                <div
                  class="w-14 h-14 rounded-lg mb-1 border border-black/5"
                  style={`background-color: ${s.hex}`}
                ></div>
                <p class="text-[9px] font-mono text-zurich-gray">{s.name}</p>
                <p class="text-[9px] font-mono text-zurich-gray">{s.hex}</p>
              </div>
            ))}
          </div>
        </div>
      </div>
    </section>

    <!-- ── Typography ─────────────────────────────────────────────── -->
    <section>
      <h2 class="text-xl font-bold mb-1">Typography</h2>
      <p class="text-sm text-zurich-gray mb-8">Inter Variable — weights 400 / 600 / 700 / 800</p>

      <div class="space-y-4 bg-white border border-zurich-border rounded-xl p-6">
        <div class="border-b border-zurich-border pb-4">
          <p class="text-[10px] font-mono text-zurich-gray mb-1">Display — 7xl / extrabold / tracking -0.04em</p>
          <p class="text-7xl font-extrabold tracking-tight leading-none">Zürich</p>
        </div>
        <div class="border-b border-zurich-border pb-4">
          <p class="text-[10px] font-mono text-zurich-gray mb-1">H1 — 5xl / extrabold</p>
          <h1 class="text-5xl font-extrabold tracking-tight">Willkommen</h1>
        </div>
        <div class="border-b border-zurich-border pb-4">
          <p class="text-[10px] font-mono text-zurich-gray mb-1">H2 — 3xl / bold</p>
          <h2 class="text-3xl font-bold tracking-tight">Bünzli AI</h2>
        </div>
        <div class="border-b border-zurich-border pb-4">
          <p class="text-[10px] font-mono text-zurich-gray mb-1">Body — base / normal</p>
          <p class="text-base leading-relaxed text-zurich-gray">Die schlausti KI für Zürich. Dini Frage, üsi Stadt.</p>
        </div>
        <div class="border-b border-zurich-border pb-4">
          <p class="text-[10px] font-mono text-zurich-gray mb-1">Small — sm / normal</p>
          <p class="text-sm text-zurich-gray">Daten vo Züri. Hosting in dr Schwiiz. Open Source.</p>
        </div>
        <div>
          <p class="text-[10px] font-mono text-zurich-gray mb-1">Mono label — xs / semibold / tracking widest / uppercase</p>
          <p class="font-mono text-xs text-zurich-blue tracking-widest uppercase font-semibold">Live connectors</p>
        </div>
      </div>

      <div class="mt-4 bg-white border border-zurich-border rounded-xl p-6 flex flex-wrap gap-4 items-baseline">
        <p class="text-[10px] font-mono text-zurich-gray w-full mb-2">Text gradients</p>
        <span class="text-4xl font-extrabold text-gradient">Zürich</span>
        <span class="stat-number">47</span>
      </div>
    </section>

    <!-- ── Shadows ────────────────────────────────────────────────── -->
    <section>
      <h2 class="text-xl font-bold mb-1">Shadows</h2>
      <p class="text-sm text-zurich-gray mb-8">3-level system matching zh.ch</p>

      <div class="flex gap-8 flex-wrap">
        <div class="text-center">
          <div class="w-32 h-20 bg-white rounded-xl shadow-short mb-3"></div>
          <p class="text-xs font-mono text-zurich-gray">shadow-short</p>
          <p class="text-[10px] text-zurich-gray/60">hover states</p>
        </div>
        <div class="text-center">
          <div class="w-32 h-20 bg-white rounded-xl shadow-regular mb-3"></div>
          <p class="text-xs font-mono text-zurich-gray">shadow-regular</p>
          <p class="text-[10px] text-zurich-gray/60">cards, panels</p>
        </div>
        <div class="text-center">
          <div class="w-32 h-20 bg-white rounded-xl shadow-long mb-3"></div>
          <p class="text-xs font-mono text-zurich-gray">shadow-long</p>
          <p class="text-[10px] text-zurich-gray/60">modals, dropdowns</p>
        </div>
      </div>
    </section>

    <!-- ── Buttons ────────────────────────────────────────────────── -->
    <section>
      <h2 class="text-xl font-bold mb-1">Buttons</h2>
      <p class="text-sm text-zurich-gray mb-8">4 variants × 3 sizes · href → &lt;a&gt;, no href → &lt;button&gt;</p>

      <div class="space-y-6 bg-white border border-zurich-border rounded-xl p-6">
        <div>
          <p class="text-[10px] font-mono text-zurich-gray uppercase tracking-wider mb-3">Variants (md)</p>
          <div class="flex flex-wrap gap-3">
            <Button variant="primary">Primary</Button>
            <Button variant="secondary">Secondary</Button>
            <Button variant="outline">Outline</Button>
            <Button variant="ghost">Ghost</Button>
            <Button variant="primary" disabled>Disabled</Button>
          </div>
        </div>
        <div>
          <p class="text-[10px] font-mono text-zurich-gray uppercase tracking-wider mb-3">Sizes (primary)</p>
          <div class="flex flex-wrap items-center gap-3">
            <Button variant="primary" size="sm">Small</Button>
            <Button variant="primary" size="md">Medium</Button>
            <Button variant="primary" size="lg">Large</Button>
          </div>
        </div>
        <div>
          <p class="text-[10px] font-mono text-zurich-gray uppercase tracking-wider mb-3">As link (href)</p>
          <div class="flex flex-wrap gap-3">
            <Button href="#" variant="primary" size="sm">Beta testen →</Button>
            <Button href="#" variant="outline" size="sm">Mitmache →</Button>
          </div>
        </div>
      </div>
    </section>

    <!-- ── Badges ─────────────────────────────────────────────────── -->
    <section>
      <h2 class="text-xl font-bold mb-1">Badges</h2>
      <p class="text-sm text-zurich-gray mb-8">4 variants · optional count suffix</p>

      <div class="bg-white border border-zurich-border rounded-xl p-6 flex flex-wrap gap-3">
        <Badge variant="blue">Open Source</Badge>
        <Badge variant="green">Swiss Hosted</Badge>
        <Badge variant="orange">Beta</Badge>
        <Badge variant="gray">Coming Soon</Badge>
        <Badge variant="blue" count="12">Connectors</Badge>
        <Badge variant="green" count="8">KB Topics</Badge>
      </div>
    </section>

    <!-- ── Cards ─────────────────────────────────────────────────── -->
    <section>
      <h2 class="text-xl font-bold mb-1">Cards</h2>
      <p class="text-sm text-zurich-gray mb-8">3 variants × 3 padding sizes · optional hover</p>

      <div class="grid sm:grid-cols-3 gap-4">
        <Card variant="default" padding="lg" hover>
          <p class="text-[10px] font-mono text-zurich-gray uppercase tracking-wider mb-2">default + hover</p>
          <h3 class="font-bold text-zurich-dark mb-1">Card Title</h3>
          <p class="text-sm text-zurich-gray">Default card with hover shadow and border transition.</p>
        </Card>
        <Card variant="blue-tint" padding="lg" hover>
          <p class="text-[10px] font-mono text-zurich-gray uppercase tracking-wider mb-2">blue-tint + hover</p>
          <h3 class="font-bold text-zurich-dark mb-1">Card Title</h3>
          <p class="text-sm text-zurich-gray">Blue-tinted card used for scenario highlights.</p>
        </Card>
        <div class="bg-zurich-navy p-2 rounded-xl">
          <Card variant="dark" padding="lg" hover>
            <p class="text-[10px] font-mono text-white/40 uppercase tracking-wider mb-2">dark + hover</p>
            <h3 class="font-bold text-white mb-1">Card Title</h3>
            <p class="text-sm text-white/60">Dark card for use on navy backgrounds.</p>
          </Card>
        </div>
      </div>
    </section>

    <!-- ── Pills ─────────────────────────────────────────────────── -->
    <section>
      <h2 class="text-xl font-bold mb-1">Pills</h2>
      <p class="text-sm text-zurich-gray mb-8">KB topics + connector chips · optional emoji, count, dashed</p>

      <div class="bg-white border border-zurich-border rounded-xl p-6 space-y-4">
        <div>
          <p class="text-[10px] font-mono text-zurich-gray uppercase tracking-wider mb-3">KB Topics (emoji + count)</p>
          <div class="flex flex-wrap gap-2">
            <Pill emoji="🏠" label="Miete & Wohne" count="47" tooltip="Rental law, tenant rights, deposit rules" />
            <Pill emoji="🏛️" label="Behörde" count="23" tooltip="Government services and forms" />
            <Pill emoji="⚖️" label="Schwiizer Rächt" count="18" tooltip="Swiss law essentials for residents" />
            <Pill emoji="🧳" label="Expats" count="12" tooltip="Relocation, permits, banking" />
          </div>
        </div>
        <div>
          <p class="text-[10px] font-mono text-zurich-gray uppercase tracking-wider mb-3">Connectors (solid + dashed)</p>
          <div class="flex flex-wrap gap-2">
            <Pill emoji="🚃" label="Abfahrte" tooltip="Live SBB departures" />
            <Pill emoji="🌦️" label="Wetter" tooltip="MeteoSwiss live weather" />
            <Pill emoji="⚡" label="Strom" tooltip="Electricity grid data" />
            <Pill emoji="🔍" label="Web Search" tooltip="Coming soon" dashed />
          </div>
        </div>
      </div>
    </section>

    <!-- ── Section Headers ────────────────────────────────────────── -->
    <section>
      <h2 class="text-xl font-bold mb-1">Section Headers</h2>
      <p class="text-sm text-zurich-gray mb-8">eyebrow + heading + subtext · light/dark themes · left/center align</p>

      <div class="space-y-8">
        <div class="bg-white border border-zurich-border rounded-xl p-8">
          <p class="text-[10px] font-mono text-zurich-gray uppercase tracking-wider mb-4">Light · center (default)</p>
          <SectionHeader
            eyebrow="Use cases"
            heading="Was chasch du frage?"
            subtext="Alles rund um Zürich — in echtem Züridütsch."
          />
        </div>

        <div class="bg-white border border-zurich-border rounded-xl p-8">
          <p class="text-[10px] font-mono text-zurich-gray uppercase tracking-wider mb-4">Light · left align</p>
          <SectionHeader
            eyebrow="Use cases"
            heading="Was chasch du frage?"
            subtext="Alles rund um Zürich — in echtem Züridütsch."
            align="left"
          />
        </div>

        <div class="bg-zurich-navy rounded-xl p-8">
          <p class="text-[10px] font-mono text-white/40 uppercase tracking-wider mb-4">Dark theme · center</p>
          <SectionHeader
            eyebrow="Dateschutz"
            heading="Dini Date ghöre dir."
            subtext="Kei Training, kei Tracking, kei Clouds im Usland."
            theme="dark"
          />
        </div>
      </div>
    </section>

    <!-- ── Live dot eyebrow ───────────────────────────────────────── -->
    <section>
      <h2 class="text-xl font-bold mb-1">Live-dot eyebrow</h2>
      <p class="text-sm text-zurich-gray mb-8">Pill with pulsing green dot — signals "real-time, live" state</p>

      <div class="bg-white border border-zurich-border rounded-xl p-6 flex flex-wrap gap-3">
        <div class="inline-flex items-center gap-2 border border-zurich-border rounded-full px-3 py-1 text-[11px] font-mono text-zurich-gray">
          <span class="w-1.5 h-1.5 rounded-full bg-tram-green animate-pulse"></span>
          Closed beta · Summer 2026
        </div>
        <div class="inline-flex items-center gap-2 border border-zurich-border rounded-full px-3 py-1 text-[11px] font-mono text-zurich-gray">
          <span class="w-1.5 h-1.5 rounded-full bg-tram-green animate-pulse"></span>
          Zürich · right now
        </div>
      </div>
    </section>

    <!-- ── Chat bubbles ───────────────────────────────────────────── -->
    <section>
      <h2 class="text-xl font-bold mb-1">Chat bubbles</h2>
      <p class="text-sm text-zurich-gray mb-8">User (right, blue) · bot (left, gray) with source caption</p>

      <div class="bg-white border border-zurich-border rounded-xl p-6 space-y-4 max-w-lg">
        <div class="flex justify-end">
          <div class="bg-zurich-blue text-white rounded-2xl rounded-tr-sm px-4 py-2.5 max-w-[85%]">
            <p class="text-sm">When's the next tram to Bürkliplatz?</p>
          </div>
        </div>
        <div class="flex justify-start">
          <div class="bg-gray-100 rounded-2xl rounded-tl-sm px-4 py-2.5 max-w-[85%]">
            <p class="text-sm text-zurich-dark leading-relaxed">Tram <b>4</b> to Bürkliplatz in <b>3 min</b> from Helmhaus.</p>
            <p class="text-[10px] text-zurich-gray/70 mt-1.5 font-mono">ZVV · live · encrypted</p>
          </div>
        </div>
        <div class="flex justify-start">
          <div class="bg-gray-100 rounded-2xl rounded-tl-sm px-4 py-3">
            <div class="flex items-center gap-1">
              <span class="w-1.5 h-1.5 rounded-full bg-zurich-gray/40 animate-bounce" style="animation-delay:0ms"></span>
              <span class="w-1.5 h-1.5 rounded-full bg-zurich-gray/40 animate-bounce" style="animation-delay:150ms"></span>
              <span class="w-1.5 h-1.5 rounded-full bg-zurich-gray/40 animate-bounce" style="animation-delay:300ms"></span>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- ── Prompt chips ───────────────────────────────────────────── -->
    <section>
      <h2 class="text-xl font-bold mb-1">Prompt chips</h2>
      <p class="text-sm text-zurich-gray mb-8">Tappable suggestions below a chat input</p>

      <div class="bg-white border border-zurich-border rounded-xl p-6">
        <div class="flex gap-2 flex-wrap">
          <button class="shrink-0 text-xs text-zurich-dark bg-white border border-zurich-border rounded-full px-3 py-1.5 hover:border-zurich-blue hover:text-zurich-blue hover:shadow-short transition-all whitespace-nowrap">
            When's the next tram to Bürkliplatz?
          </button>
          <button class="shrink-0 text-xs text-zurich-dark bg-white border border-zurich-border rounded-full px-3 py-1.5 hover:border-zurich-blue hover:text-zurich-blue hover:shadow-short transition-all whitespace-nowrap">
            How warm is the Zürichsee right now?
          </button>
        </div>
      </div>
    </section>

    <!-- ── Live status cell ───────────────────────────────────────── -->
    <section>
      <h2 class="text-xl font-bold mb-1">Live status cell</h2>
      <p class="text-sm text-zurich-gray mb-8">Grid tile with emoji, live dot, label, value+unit, meta</p>

      <div class="grid grid-cols-2 md:grid-cols-3 gap-3 max-w-2xl">
        <div class="bg-white border border-zurich-border rounded-xl p-5 hover:shadow-regular hover:border-zurich-blue/30 transition-all">
          <div class="flex items-center justify-between mb-3">
            <span class="text-xl" aria-hidden="true">🚃</span>
            <span class="flex items-center gap-1 text-[10px] font-mono text-tram-green">
              <span class="w-1.5 h-1.5 rounded-full bg-tram-green animate-pulse"></span>live
            </span>
          </div>
          <p class="text-[11px] font-mono text-zurich-gray/80 uppercase tracking-wide mb-2 leading-tight">Next tram · Paradeplatz</p>
          <p class="text-2xl font-extrabold tabular-nums leading-none mb-1 text-zurich-blue">
            4<span class="text-sm font-medium text-zurich-gray ml-1">to Tiefenbrunnen</span>
          </p>
          <p class="text-xs text-zurich-gray/70 mt-1.5">in 2 min</p>
        </div>
        <div class="bg-white border border-zurich-border rounded-xl p-5 hover:shadow-regular hover:border-zurich-blue/30 transition-all">
          <div class="flex items-center justify-between mb-3">
            <span class="text-xl" aria-hidden="true">🌡️</span>
            <span class="flex items-center gap-1 text-[10px] font-mono text-tram-green">
              <span class="w-1.5 h-1.5 rounded-full bg-tram-green animate-pulse"></span>live
            </span>
          </div>
          <p class="text-[11px] font-mono text-zurich-gray/80 uppercase tracking-wide mb-2 leading-tight">Zürichsee · Mythenquai</p>
          <p class="text-2xl font-extrabold tabular-nums leading-none mb-1 text-badi-orange">
            22.4<span class="text-sm font-medium text-zurich-gray ml-1">°C</span>
          </p>
          <p class="text-xs text-zurich-gray/70 mt-1.5">swim-ready</p>
        </div>
        <div class="bg-white border border-zurich-border rounded-xl p-5 hover:shadow-regular hover:border-zurich-blue/30 transition-all">
          <div class="flex items-center justify-between mb-3">
            <span class="text-xl" aria-hidden="true">💨</span>
            <span class="flex items-center gap-1 text-[10px] font-mono text-tram-green">
              <span class="w-1.5 h-1.5 rounded-full bg-tram-green animate-pulse"></span>live
            </span>
          </div>
          <p class="text-[11px] font-mono text-zurich-gray/80 uppercase tracking-wide mb-2 leading-tight">Air · Stampfenbach</p>
          <p class="text-2xl font-extrabold tabular-nums leading-none mb-1 text-tram-green">
            18<span class="text-sm font-medium text-zurich-gray ml-1">AQI</span>
          </p>
          <p class="text-xs text-zurich-gray/70 mt-1.5">good</p>
        </div>
      </div>

      <p class="text-xs text-zurich-gray mt-4">Accent color encodes category: <b>blue</b> transit/infra, <b>badi-orange</b> water/warmth, <b>tram-green</b> air/safety.</p>
    </section>

    <!-- ── Comparison column ──────────────────────────────────────── -->
    <section>
      <h2 class="text-xl font-bold mb-1">Comparison column</h2>
      <p class="text-sm text-zurich-gray mb-8">Side-by-side AI answers with verdict color — Bünzli column is emphasized</p>

      <div class="grid sm:grid-cols-3 gap-4">
        <div class="bg-white border border-zurich-border rounded-xl p-5">
          <p class="text-[11px] font-mono text-zurich-gray/70 uppercase tracking-wider mb-3">ChatGPT</p>
          <p class="text-sm text-zurich-dark leading-relaxed italic mb-3">"I don't have access to real-time schedules…"</p>
          <p class="text-[11px] font-mono text-red-500/80">Refuses. No real-time access.</p>
        </div>
        <div class="bg-white border border-zurich-border rounded-xl p-5">
          <p class="text-[11px] font-mono text-zurich-gray/70 uppercase tracking-wider mb-3">Gemini</p>
          <p class="text-sm text-zurich-dark leading-relaxed italic mb-3">"Tram 11 typically runs until around midnight…"</p>
          <p class="text-[11px] font-mono text-amber-600/90">Vague. Hedges. Often wrong.</p>
        </div>
        <div class="bg-white border border-zurich-border rounded-xl p-5 shadow-regular ring-1 ring-zurich-blue/10">
          <p class="text-[11px] font-mono text-zurich-blue uppercase tracking-wider mb-3">Bünzli</p>
          <p class="text-sm text-zurich-dark leading-relaxed mb-3"><b>01:20</b> from Rehalp, then <b>night bus N14</b>.</p>
          <p class="text-[11px] font-mono text-tram-green">Specific. Sourced. Right.</p>
        </div>
      </div>
    </section>

    <!-- ── Scene card ─────────────────────────────────────────────── -->
    <section>
      <h2 class="text-xl font-bold mb-1">Scene card</h2>
      <p class="text-sm text-zurich-gray mb-8">Time-of-day scenario with question, chat answer, and source chain</p>

      <div class="bg-white border border-zurich-border rounded-xl p-6 max-w-lg">
        <p class="font-mono text-xs text-zurich-gray tracking-wider mb-2">07:42 · MORNING 🌤️</p>
        <h3 class="text-xl font-bold text-zurich-dark mb-4">Should I run or walk to the tram?</h3>
        <div class="flex items-center gap-2 mb-2">
          <div class="w-6 h-6 rounded-full bg-zurich-blue/10 flex items-center justify-center">
            <img src="/zh-lion.svg" alt="" aria-hidden="true" class="w-3 h-3" />
          </div>
          <p class="text-xs font-semibold text-zurich-dark">Bünzli</p>
          <span class="flex items-center gap-1 text-[10px] font-mono text-tram-green ml-auto">
            <span class="w-1.5 h-1.5 rounded-full bg-tram-green animate-pulse"></span>live
          </span>
        </div>
        <p class="text-sm text-zurich-dark leading-relaxed mb-3">Walk. <b>Tram 11</b> leaves in <b>4 min</b>, you'll make it. Rain starts at 08:15 — grab an umbrella.</p>
        <p class="text-[11px] font-mono text-zurich-gray/70">Departures · Weather</p>
      </div>
    </section>

    <!-- ── Architecture hop ───────────────────────────────────────── -->
    <section>
      <h2 class="text-xl font-bold mb-1">Architecture hop</h2>
      <p class="text-sm text-zurich-gray mb-8">Request-path diagram — each hop labeled, arrows between</p>

      <div class="bg-zurich-blue text-white rounded-xl p-8">
        <div class="flex flex-col sm:flex-row items-center justify-between gap-4">
          {['You', 'Swiss ISP', 'Infomaniak · Geneva', 'Apertus 70B'].map((label, i, arr) => (
            <>
              <div class="flex flex-col items-center gap-2 text-center">
                <div class="w-12 h-12 rounded-full bg-white/10 border border-white/20 flex items-center justify-center text-xl">
                  {['👤', '🌐', '🏢', '🧠'][i]}
                </div>
                <p class="text-[11px] font-mono uppercase tracking-wider">{label}</p>
              </div>
              {i < arr.length - 1 && <span class="text-white/40 text-xl">→</span>}
            </>
          ))}
        </div>
        <p class="text-sm text-white/70 leading-relaxed text-center mt-6">The entire request path — from your browser to the model and back. Zero US infrastructure. Zero third-party telemetry.</p>
      </div>
    </section>

    <!-- ── Progress meter ─────────────────────────────────────────── -->
    <section>
      <h2 class="text-xl font-bold mb-1">Progress meter</h2>
      <p class="text-sm text-zurich-gray mb-8">Thin horizontal bar with mono label/percent above</p>

      <div class="bg-white border border-zurich-border rounded-xl p-6 max-w-sm">
        <div class="flex items-center justify-between text-[11px] font-mono text-zurich-gray mb-1.5">
          <span>47 of 500 spots taken</span>
          <span>9%</span>
        </div>
        <div class="h-1.5 bg-zurich-border rounded-full overflow-hidden">
          <div class="h-full bg-zurich-blue rounded-full" style="width: 9%"></div>
        </div>
      </div>
    </section>

    <!-- ── Data-animate scroll reveal ─────────────────────────────── -->
    <section>
      <h2 class="text-xl font-bold mb-1">Scroll reveal</h2>
      <p class="text-sm text-zurich-gray mb-8"><code class="font-mono text-xs bg-zh-black-10 px-1.5 py-0.5 rounded">data-animate</code> on any element fades + rises it in on intersection · <code class="font-mono text-xs bg-zh-black-10 px-1.5 py-0.5 rounded">data-animate-stagger</code> on a parent staggers children</p>

      <div class="bg-white border border-zurich-border rounded-xl p-6">
        <p class="text-xs text-zurich-gray leading-relaxed">Starts at <code class="font-mono">opacity: 0; translateY(28px)</code>, animates to visible over 0.65s with a cubic-bezier(0.16, 1, 0.3, 1) ease. Observer is wired in <code class="font-mono">Base.astro</code> — no per-component JS needed. Respects <code class="font-mono">prefers-reduced-motion</code> via the global stylesheet.</p>
      </div>
    </section>

  </div>
</body>
</html>
