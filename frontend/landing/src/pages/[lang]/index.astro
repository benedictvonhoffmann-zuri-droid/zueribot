---
import { LOCALES, type Locale } from '../../i18n/locales';
import { useTranslations } from '../../i18n/ui';
import Base from '../../layouts/Base.astro';

import Hero from '../../components/sections/Hero.astro';
import LiveStatusBoard from '../../components/sections/LiveStatusBoard.astro';
import DayWithBunzli from '../../components/sections/DayWithBunzli.astro';
import CompareAI from '../../components/sections/CompareAI.astro';
import PrivacyArchitecture from '../../components/sections/PrivacyArchitecture.astro';
import OpenSource from '../../components/sections/OpenSource.astro';
import JoinStrip from '../../components/sections/JoinStrip.astro';

export function getStaticPaths() {
  return LOCALES.map(lang => ({ params: { lang } }));
}

const { lang } = Astro.params as { lang: Locale };
const t = useTranslations(lang);
---

<Base lang={lang} t={t}>
  <Hero t={t} lang={lang} />
  <LiveStatusBoard t={t} />
  <DayWithBunzli t={t} />
  <CompareAI t={t} />
  <PrivacyArchitecture t={t} />
  <OpenSource t={t} />
  <JoinStrip t={t} />
</Base>
