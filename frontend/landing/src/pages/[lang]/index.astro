---
import { LOCALES, type Locale } from '../../i18n/locales';
import { useTranslations } from '../../i18n/ui';
import Base from '../../layouts/Base.astro';

import Hero from '../../components/sections/Hero.astro';
import Scenarios from '../../components/sections/Scenarios.astro';
import HowItWorks from '../../components/sections/HowItWorks.astro';
import TechStack from '../../components/sections/TechStack.astro';
import PrivacyFirst from '../../components/sections/PrivacyFirst.astro';
import CommunityFuture from '../../components/sections/CommunityFuture.astro';

export function getStaticPaths() {
  return LOCALES.map(lang => ({ params: { lang } }));
}

const { lang } = Astro.params as { lang: Locale };
const t = useTranslations(lang);
---

<Base lang={lang} t={t}>
  <Hero t={t} lang={lang} />
  <Scenarios t={t} />
  <HowItWorks t={t} />
  <TechStack t={t} />
  <PrivacyFirst t={t} />
  <CommunityFuture t={t} />
</Base>
