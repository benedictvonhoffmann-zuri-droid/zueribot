---
import SectionHeader from '../ui/SectionHeader.astro';
import type { TranslationSchema } from '../../i18n/translations/de';

interface Props {
  t: TranslationSchema;
}

const { t } = Astro.props;

const githubUrl = 'https://github.com/benedictvonhoffmann/zuribot';

const techLayers = [
  { emoji: '🌐', label: t.techFrontend,  tech: 'Astro + Tailwind · Open WebUI', desc: t.techFrontendDesc },
  { emoji: '🔑', label: t.techAuth,      tech: 'ZITADEL',                        desc: t.techAuthDesc },
  { emoji: '⚡', label: t.techAPI,       tech: 'FastAPI (Python)',                desc: t.techAPIDesc },
  { emoji: '🧠', label: t.techAI,        tech: 'Apertus 70B · Infomaniak',       desc: t.techAIDesc },
  { emoji: '📚', label: t.techKnowledge, tech: 'ChromaDB',                        desc: t.techKnowledgeDesc },
  { emoji: '🏔️', label: t.techHosting,   tech: 'Infomaniak · Zürich',             desc: t.techHostingDesc },
];
---

<section id="tech" class="py-20 sm:py-28 bg-white border-t border-zurich-border">
  <div class="max-w-6xl mx-auto px-4 sm:px-6">

    <div class="mb-12" data-animate>
      <SectionHeader
        eyebrow={t.techSectionTagline}
        heading={t.techSectionTitle}
        subtext={t.techSectionSubtitle}
      />
    </div>

    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-4 max-w-5xl mx-auto mb-10" data-animate-stagger>
      {techLayers.map(layer => (
        <div class="bg-white border border-zurich-border rounded-xl p-5 hover:border-zurich-blue/30 hover:shadow-short transition-all duration-200">
          <div class="flex items-center gap-3 mb-3">
            <div class="w-9 h-9 rounded-lg bg-zurich-blue/8 flex items-center justify-center text-lg shrink-0">
              {layer.emoji}
            </div>
            <div>
              <p class="font-semibold text-sm text-zurich-dark leading-none mb-0.5">{layer.label}</p>
              <p class="text-[10px] font-mono text-zurich-gray">{layer.tech}</p>
            </div>
          </div>
          <p class="text-xs text-zurich-gray leading-relaxed">{layer.desc}</p>
        </div>
      ))}
    </div>

    <div class="text-center" data-animate>
      <a
        href={githubUrl}
        target="_blank"
        rel="noopener noreferrer"
        class="inline-flex items-center gap-2 bg-zurich-blue/5 border border-zurich-blue/20 rounded-full px-5 py-2.5 text-sm text-zurich-blue font-medium hover:bg-zurich-blue/10 hover:shadow-short transition-all duration-200"
      >
        <svg width="16" height="16" viewBox="0 0 16 16" fill="currentColor" aria-hidden="true">
          <path d="M8 0C3.58 0 0 3.58 0 8c0 3.54 2.29 6.53 5.47 7.59.4.07.55-.17.55-.38 0-.19-.01-.82-.01-1.49-2.01.37-2.53-.49-2.69-.94-.09-.23-.48-.94-.82-1.13-.28-.15-.68-.52-.01-.53.63-.01 1.08.58 1.23.82.72 1.21 1.87.87 2.33.66.07-.52.28-.87.51-1.07-1.78-.2-3.64-.89-3.64-3.95 0-.87.31-1.59.82-2.15-.08-.2-.36-1.02.08-2.12 0 0 .67-.21 2.2.82.64-.18 1.32-.27 2-.27.68 0 1.36.09 2 .27 1.53-1.04 2.2-.82 2.2-.82.44 1.1.16 1.92.08 2.12.51.56.82 1.27.82 2.15 0 3.07-1.87 3.75-3.65 3.95.29.25.54.73.54 1.48 0 1.07-.01 1.93-.01 2.2 0 .21.15.46.55.38A8.013 8.013 0 0016 8c0-4.42-3.58-8-8-8z"/>
        </svg>
        {t.techOpenSource}
      </a>
    </div>

  </div>
</section>
