---
import Button from '../ui/Button.astro';
import Eyebrow from '../ui/Eyebrow.astro';
import type { TranslationSchema } from '../../i18n/translations/de';
import type { Locale } from '../../i18n/locales';

interface Props {
  t: TranslationSchema;
  lang: Locale;
}

const { t } = Astro.props;

const repoHref = 'https://github.com/benedictvonhoffmann-zuri-droid/zueribot';

const prompts = [
  { q: t.heroPrompt1, a: t.heroReply1, src: t.heroReply1Source },
  { q: t.heroPrompt2, a: t.heroReply2, src: t.heroReply2Source },
  { q: t.heroPrompt3, a: t.heroReply3, src: t.heroReply3Source },
  { q: t.heroPrompt4, a: t.heroReply4, src: t.heroReply4Source },
];
---

<section class="relative pt-24 pb-16 sm:pt-28 sm:pb-20 overflow-hidden bg-white">
  <!-- Zürich-flag diagonal hatching — sparse, calm, Swiss -->
  <svg class="absolute inset-0 w-full h-full opacity-[0.035] pointer-events-none" aria-hidden="true">
    <defs>
      <pattern id="zh-diag" width="120" height="120" patternUnits="userSpaceOnUse">
        <!-- Only the diagonal, no cell border — cleaner, less nervous -->
        <line x1="0" y1="120" x2="120" y2="0" stroke="#0070B4" stroke-width="1"/>
      </pattern>
    </defs>
    <rect width="100%" height="100%" fill="url(#zh-diag)"/>
  </svg>

  <div class="relative max-w-6xl mx-auto px-4 sm:px-6">
    <div class="grid lg:grid-cols-2 gap-12 lg:gap-16 items-center">

      <!-- Left: copy -->
      <div class="min-w-0">
        <p class="mb-6">
          <Eyebrow tilt={-1}>{t.heroEyebrow}</Eyebrow>
        </p>

        <h1 class="text-5xl sm:text-6xl lg:text-7xl font-extrabold tracking-tight leading-[1.05] sm:leading-[1.02] mb-6 text-zurich-dark break-words hyphens-auto" lang="de">
          {t.heroHeadline1}
          <br />
          <span class="text-gradient">{t.heroHeadline2}</span>
        </h1>

        <p class="text-base sm:text-lg text-zurich-gray leading-relaxed mb-8 max-w-md" set:html={t.heroSub} />

        <div class="flex flex-col sm:flex-row gap-3 mb-10">
          <Button variant="primary" size="lg" class="w-full sm:w-auto" data-open-contact="beta">
            {t.heroCtaPrimary}
            <svg width="14" height="14" viewBox="0 0 14 14" fill="none" aria-hidden="true">
              <path d="M2.5 7h9M8 3.5l3.5 3.5L8 10.5" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
            </svg>
          </Button>
          <Button href={repoHref} variant="outline" size="lg" class="w-full sm:w-auto bg-white" target="_blank" rel="noopener noreferrer">
            {t.heroCtaSecondary}
          </Button>
        </div>

        <div class="flex flex-wrap items-center justify-center sm:justify-start gap-x-4 gap-y-2 text-xs text-zurich-gray/70 font-mono">
          <span class="flex items-center gap-1.5">🛡️ {t.heroTrustNoTracking}</span>
          <span class="flex items-center gap-1.5">🇨🇭 {t.heroTrustSwissHosted}</span>
          <span class="flex items-center gap-1.5">💻 {t.heroTrustOpenSource}</span>
        </div>
      </div>

      <!-- Right: Chat replay -->
      <div class="min-w-0">
        <div class="bg-white border border-zurich-border rounded-md shadow-regular overflow-hidden">

          <!-- Chat header -->
          <div class="flex items-center gap-3 px-5 py-3.5 border-b border-zurich-border bg-zh-black-5/60">
            <button id="easter-egg-trigger" class="w-8 h-8 rounded-full bg-zurich-blue/10 flex items-center justify-center hover:bg-zurich-blue/20 transition-colors" aria-label="Züri">
              <img src="/zh-lion.svg" alt="" aria-hidden="true" class="w-4 h-4" style="filter: brightness(0) saturate(100%)" />
            </button>
            <div class="flex-1">
              <p class="text-sm font-semibold text-zurich-dark">Bünzli AI</p>
              <p class="text-[10px] text-tram-green font-mono flex items-center gap-1">
                <span class="w-1 h-1 rounded-full bg-tram-green"></span>
                {t.heroStatusDot}
              </p>
            </div>
            <button
              id="chat-reset"
              class="text-[11px] font-mono text-zurich-gray hover:text-zurich-blue transition-colors"
              aria-label="Reset chat"
            >
              {t.heroReset}
            </button>
          </div>

          <!-- Messages -->
          <div
            id="chat-messages"
            class="px-5 py-5 space-y-4 min-h-[320px] max-h-[320px] overflow-y-auto"
            aria-live="polite"
          ></div>

          <!-- Prompt chips -->
          <div class="border-t border-zurich-border bg-zh-black-5/40 px-4 py-3">
            <p class="text-[10px] font-mono text-zurich-gray/70 mb-2 uppercase tracking-wider">
              {t.heroReplayHint}
            </p>
            <div class="flex gap-2 overflow-x-auto scrollbar-none -mx-1 px-1 pb-1">
              {prompts.map((p, i) => (
                <button
                  class="chat-chip shrink-0 text-xs text-zurich-dark bg-white border border-zurich-border rounded-full px-3 py-1.5 hover:border-zurich-blue hover:text-zurich-blue hover:shadow-short transition-all whitespace-nowrap"
                  data-idx={i}
                >
                  {p.q}
                </button>
              ))}
            </div>
          </div>
        </div>
      </div>

    </div>
  </div>
</section>

<script define:vars={{ prompts }}>
  const messagesEl = document.getElementById('chat-messages');
  const chipsEl = document.querySelectorAll('.chat-chip');
  const resetBtn = document.getElementById('chat-reset');
  if (!messagesEl) throw new Error('chat messages not found');

  let currentRun = 0;

  const sleep = (ms) => new Promise(r => setTimeout(r, ms));

  function addUser(text) {
    const el = document.createElement('div');
    el.className = 'flex justify-end opacity-0 transition-opacity duration-300';
    el.innerHTML = `<div class="bg-zurich-blue text-white rounded-md rounded-tr-sm px-4 py-2.5 max-w-[85%]"><p class="text-sm">${text}</p></div>`;
    messagesEl.appendChild(el);
    requestAnimationFrame(() => { el.style.opacity = '1'; });
    messagesEl.scrollTop = messagesEl.scrollHeight;
    return el;
  }

  function addTyping() {
    const el = document.createElement('div');
    el.className = 'flex justify-start typing-indicator';
    el.innerHTML = `<div class="bg-gray-100 rounded-md rounded-tl-sm px-4 py-3"><div class="flex items-center gap-1"><span class="w-1.5 h-1.5 rounded-full bg-zurich-gray/40 animate-bounce" style="animation-delay:0ms"></span><span class="w-1.5 h-1.5 rounded-full bg-zurich-gray/40 animate-bounce" style="animation-delay:150ms"></span><span class="w-1.5 h-1.5 rounded-full bg-zurich-gray/40 animate-bounce" style="animation-delay:300ms"></span></div></div>`;
    messagesEl.appendChild(el);
    messagesEl.scrollTop = messagesEl.scrollHeight;
    return el;
  }

  function addBot(sourceText) {
    const el = document.createElement('div');
    el.className = 'flex justify-start opacity-0 transition-opacity duration-300';
    el.innerHTML = `<div class="bg-gray-100 rounded-md rounded-tl-sm px-4 py-2.5 max-w-[85%]"><p class="text-sm text-zurich-dark leading-relaxed bot-body"></p><p class="text-[10px] text-zurich-gray/70 mt-1.5 font-mono">${sourceText}</p></div>`;
    messagesEl.appendChild(el);
    requestAnimationFrame(() => { el.style.opacity = '1'; });
    return el.querySelector('.bot-body');
  }

  async function streamInto(target, html, runId) {
    // Word-by-word reveal, preserving HTML tags (<b> etc.)
    const tmp = document.createElement('div');
    tmp.innerHTML = html;
    const nodes = Array.from(tmp.childNodes);
    target.innerHTML = '';

    for (const node of nodes) {
      if (runId !== currentRun) return;
      if (node.nodeType === Node.TEXT_NODE) {
        const words = node.textContent.split(/(\s+)/);
        for (const w of words) {
          if (runId !== currentRun) return;
          target.appendChild(document.createTextNode(w));
          messagesEl.scrollTop = messagesEl.scrollHeight;
          await sleep(30);
        }
      } else {
        const clone = node.cloneNode(true);
        target.appendChild(clone);
        messagesEl.scrollTop = messagesEl.scrollHeight;
        await sleep(60);
      }
    }
  }

  async function play(idx) {
    currentRun++;
    const runId = currentRun;
    messagesEl.innerHTML = '';
    const p = prompts[idx];
    if (!p) return;

    addUser(p.q);
    await sleep(550);
    if (runId !== currentRun) return;

    const typing = addTyping();
    await sleep(900);
    if (runId !== currentRun) { typing.remove(); return; }
    typing.remove();

    const target = addBot(p.src);
    await streamInto(target, p.a, runId);
  }

  chipsEl.forEach(btn => {
    btn.addEventListener('click', () => {
      const i = parseInt(btn.getAttribute('data-idx') || '0', 10);
      play(i);
    });
  });

  resetBtn?.addEventListener('click', () => play(0));

  // Auto-play the first prompt once the hero is in view
  const io = new IntersectionObserver((entries) => {
    entries.forEach(e => {
      if (e.isIntersecting) {
        play(0);
        io.disconnect();
      }
    });
  }, { threshold: 0.2 });
  io.observe(messagesEl);
</script>

<!-- Easter egg overlay -->
<div
  id="zh-overlay"
  class="fixed inset-0 z-[200] flex flex-col items-center justify-center bg-zurich-blue opacity-0 pointer-events-none"
  style="transition: opacity 0.35s cubic-bezier(.2,.7,.2,1)"
  aria-hidden="true"
>
  <img src="/zh-lion.svg" alt="" class="w-20 h-auto mb-8 opacity-90" style="filter: brightness(0) invert(1)" />
  <p class="text-white text-5xl sm:text-7xl font-extrabold tracking-tight text-center leading-tight px-6">
    Züri isch ois.
  </p>
  <p class="mt-4 text-white/60 text-lg font-mono tracking-wide">— immer gsi, immer no</p>
  <button
    id="zh-overlay-close"
    class="mt-12 text-white/50 hover:text-white/90 text-sm font-mono transition-colors"
  >
    [ schlüsse ]
  </button>
</div>

<script>
  const trigger = document.getElementById('easter-egg-trigger');
  const overlay = document.getElementById('zh-overlay');
  const closeBtn = document.getElementById('zh-overlay-close');

  function openOverlay() {
    if (!overlay) return;
    overlay.style.pointerEvents = 'auto';
    overlay.style.opacity = '1';
    overlay.setAttribute('aria-hidden', 'false');
    document.body.style.overflow = 'hidden';
  }

  function closeOverlay() {
    if (!overlay) return;
    overlay.style.opacity = '0';
    overlay.style.pointerEvents = 'none';
    overlay.setAttribute('aria-hidden', 'true');
    document.body.style.overflow = '';
  }

  trigger?.addEventListener('click', openOverlay);
  closeBtn?.addEventListener('click', closeOverlay);
  overlay?.addEventListener('click', (e) => {
    if (e.target === overlay) closeOverlay();
  });
  document.addEventListener('keydown', (e) => {
    if (e.key === 'Escape') closeOverlay();
  });
</script>

<style>
  .scrollbar-none::-webkit-scrollbar { display: none; }
  .scrollbar-none { scrollbar-width: none; }
</style>
