---
import Button from '../ui/Button.astro';
import type { TranslationSchema } from '../../i18n/translations/de';
import type { Locale } from '../../i18n/locales';

interface Props {
  t: TranslationSchema;
  lang: Locale;
}

const { t, lang } = Astro.props;
const { hero, cta } = t;

const betaHref = `mailto:sali@buenzli.space?subject=${encodeURIComponent(cta.betaSubject)}&body=${encodeURIComponent(cta.betaBody)}`;
const collabHref = `mailto:sali@buenzli.space?subject=${encodeURIComponent(cta.collabSubject)}&body=${encodeURIComponent(cta.collabBody)}`;
---

<section class="bg-zurich-blue text-white py-24 sm:py-36 relative overflow-hidden">
  <!-- Swiss grid background pattern -->
  <div class="absolute inset-0 opacity-5 pointer-events-none" aria-hidden="true">
    <svg width="100%" height="100%" xmlns="http://www.w3.org/2000/svg">
      <defs>
        <pattern id="grid" width="60" height="60" patternUnits="userSpaceOnUse">
          <path d="M 60 0 L 0 0 0 60" fill="none" stroke="white" stroke-width="1"/>
        </pattern>
      </defs>
      <rect width="100%" height="100%" fill="url(#grid)" />
    </svg>
  </div>

  <div class="max-w-6xl mx-auto px-4 sm:px-6 relative">
    <p class="text-zurich-blue-light text-sm font-semibold uppercase tracking-widest mb-6">
      {hero.eyebrow}
    </p>
    <h1 class="text-4xl sm:text-6xl lg:text-7xl font-bold leading-tight tracking-tight max-w-4xl mb-6">
      {hero.headline}
    </h1>
    <p class="text-lg sm:text-xl text-white/80 max-w-2xl mb-10 leading-relaxed">
      {hero.subline}
    </p>
    <div class="flex flex-col sm:flex-row gap-4">
      <Button href={betaHref} variant="secondary" label={hero.ctaBeta} note={hero.ctaBetaNote} />
      <Button href={collabHref} variant="primary" label={hero.ctaCollaborate} note={hero.ctaCollabNote} />
    </div>
  </div>
</section>
