---
import SectionHeader from '../ui/SectionHeader.astro';
import type { TranslationSchema } from '../../i18n/translations/de';

interface Props {
  t: TranslationSchema;
}

const { t } = Astro.props;

const columns = [
  {
    key: 'chatgpt',
    label: t.compareChatGPTLabel,
    icon: 'CG',
    iconBg: 'bg-zh-black-5 text-zurich-gray',
    answer: t.compareChatGPTAnswer,
    verdict: t.compareChatGPTVerdict,
    verdictColor: 'text-red-500/80',
  },
  {
    key: 'gemini',
    label: t.compareGeminiLabel,
    icon: 'G',
    iconBg: 'bg-zh-black-5 text-zurich-gray',
    answer: t.compareGeminiAnswer,
    verdict: t.compareGeminiVerdict,
    verdictColor: 'text-amber-600/90',
  },
  {
    key: 'bunzli',
    label: t.compareBunzliLabel,
    icon: '🦁',
    iconBg: 'bg-zurich-blue/10',
    answer: t.compareBunzliAnswer,
    source: t.compareBunzliSource,
    verdict: t.compareBunzliVerdict,
    verdictColor: 'text-tram-green',
    highlight: true,
  },
];
---

<section id="compare" class="py-20 sm:py-28 bg-zh-black-5">
  <div class="max-w-6xl mx-auto px-4 sm:px-6">

    <div class="mb-12" data-animate>
      <SectionHeader
        eyebrow={t.compareEyebrow}
        heading={t.compareHeadline}
        subtext={t.compareSub}
      />
    </div>

    <!-- Question banner -->
    <div class="max-w-3xl mx-auto mb-8" data-animate>
      <div class="bg-white border border-zurich-border rounded-xl px-6 py-4 flex items-center gap-4">
        <span class="text-xs font-mono text-zurich-gray/60 uppercase tracking-wider shrink-0">Q</span>
        <p class="text-base sm:text-lg text-zurich-dark font-medium italic">
          "{t.compareQuestion}"
        </p>
      </div>
    </div>

    <!-- 3 columns -->
    <div class="grid md:grid-cols-3 gap-4" data-animate>
      {columns.map((c) => (
        <div class:list={[
          'rounded-xl border p-5 flex flex-col',
          c.highlight
            ? 'bg-white border-zurich-blue/40 shadow-regular ring-1 ring-zurich-blue/10'
            : 'bg-white border-zurich-border opacity-90',
        ]}>
          <div class="flex items-center gap-2 mb-4">
            <div class:list={['w-8 h-8 rounded-full flex items-center justify-center text-sm font-bold', c.iconBg]}>
              {c.icon}
            </div>
            <span class="text-sm font-semibold text-zurich-dark">{c.label}</span>
          </div>

          <p class:list={[
            'text-sm leading-relaxed mb-4 flex-1',
            c.highlight ? 'text-zurich-dark' : 'text-zurich-gray',
          ]} set:html={c.answer} />

          {c.source && (
            <p class="text-[10px] font-mono text-zurich-gray/70 mb-3">{c.source}</p>
          )}

          <div class:list={['text-xs font-mono pt-3 border-t', c.highlight ? 'border-zurich-blue/20' : 'border-zurich-border']}>
            <span class:list={[c.verdictColor, 'font-semibold']}>{c.verdict}</span>
          </div>
        </div>
      ))}
    </div>

    <p class="text-center text-sm text-zurich-gray mt-10 max-w-2xl mx-auto" data-animate>
      {t.compareFooter}
    </p>
  </div>
</section>
