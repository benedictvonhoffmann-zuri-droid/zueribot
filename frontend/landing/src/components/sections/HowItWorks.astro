---
import SectionWrapper from '../ui/SectionWrapper.astro';
import type { TranslationSchema } from '../../i18n/translations/de';

interface Props {
  t: TranslationSchema;
}

const { t } = Astro.props;
const { howItWorks } = t;
---

<SectionWrapper id="how-it-works" bg="off-white">
  <div class="text-center mb-14" data-animate>
    <p class="section-label mb-3">04</p>
    <h2 class="section-heading text-zurich-dark mb-4">{howItWorks.heading}</h2>
    <p class="text-zurich-gray text-lg max-w-xl mx-auto">{howItWorks.subline}</p>
  </div>

  <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-5 max-w-5xl mx-auto" data-animate-stagger>
    {howItWorks.items.map((item, i) => (
      <div class="how-card group relative p-6 rounded-2xl bg-white border border-zurich-border hover:border-zurich-blue/30 hover:shadow-lg transition-all duration-300 hover:-translate-y-0.5 overflow-hidden">
        <!-- Step number watermark -->
        <span class="how-step-num absolute top-4 right-5 text-5xl font-black text-zurich-dark/5 tabular-nums leading-none select-none">
          {String(i + 1).padStart(2, '0')}
        </span>

        <span class="text-2xl mb-4 block group-hover:scale-110 transition-transform duration-200">{item.icon}</span>
        <h3 class="font-bold text-zurich-dark text-base mb-2.5">{item.title}</h3>
        <p class="text-zurich-gray text-sm leading-relaxed">{item.text}</p>
      </div>
    ))}
  </div>
</SectionWrapper>
