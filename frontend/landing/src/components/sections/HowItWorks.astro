---
import type { TranslationSchema } from '../../i18n/translations/de';

interface Props {
  t: TranslationSchema;
}

const { t } = Astro.props;

const suggestMailto = `mailto:hello@buenzli.space?subject=${encodeURIComponent('Connector Suggestion - buenzli.space')}&body=${encodeURIComponent("Hi Buenzli Team,\n\nI'd like to suggest a new connector:\n\nData source: \nWhat it would do: \nWhy it's useful: \n\nBest regards")}`;

const steps = [
  { num: '1', title: t.howStep1Title, desc: t.howStep1Desc },
  { num: '2', title: t.howStep2Title, desc: t.howStep2Desc },
  { num: '3', title: t.howStep3Title, desc: t.howStep3Desc },
];

const knowledgeTopics = [
  { emoji: '🏠', label: t.kbRenting,       count: t.kbRentingCount,        desc: t.kbRentingDesc },
  { emoji: '🏛️', label: t.kbGovernment,    count: t.kbGovernmentCount,     desc: t.kbGovernmentDesc },
  { emoji: '📰', label: t.kbNews,           count: t.kbNewsCount,           desc: t.kbNewsDesc },
  { emoji: '🍽️', label: t.kbFood,           count: t.kbFoodCount,           desc: t.kbFoodDesc },
  { emoji: '📂', label: t.kbOpenData,       count: t.kbOpenDataCount,       desc: t.kbOpenDataDesc },
  { emoji: '🏘️', label: t.kbNeighbourhoods, count: t.kbNeighbourhoodsCount, desc: t.kbNeighbourhoodsDesc },
  { emoji: '🧳', label: t.kbExpat,          count: t.kbExpatCount,          desc: t.kbExpatDesc },
  { emoji: '⚖️', label: t.kbSwissLaw,       count: t.kbSwissLawCount,       desc: t.kbSwissLawDesc },
];

const connectors = [
  { emoji: '🚃', label: t.connectorDepartures,     desc: t.connectorDeparturesDesc,     dashed: false },
  { emoji: '🗺️', label: t.connectorConnections,    desc: t.connectorConnectionsDesc,    dashed: false },
  { emoji: '🌦️', label: t.connectorWeather,         desc: t.connectorWeatherDesc,         dashed: false },
  { emoji: '💨', label: t.connectorAirQuality,      desc: t.connectorAirQualityDesc,      dashed: false },
  { emoji: '🚰', label: t.connectorDrinkingWater,   desc: t.connectorDrinkingWaterDesc,   dashed: false },
  { emoji: '🌡️', label: t.connectorWaterTemp,       desc: t.connectorWaterTempDesc,       dashed: false },
  { emoji: '⚡', label: t.connectorElectricity,     desc: t.connectorElectricityDesc,     dashed: false },
  { emoji: '📍', label: t.connectorPOI,             desc: t.connectorPOIDesc,             dashed: false },
  { emoji: '🍽️', label: t.connectorVenues,          desc: t.connectorVenuesDesc,          dashed: false },
  { emoji: '🎪', label: t.connectorEvents,          desc: t.connectorEventsDesc,          dashed: false },
  { emoji: '🚶', label: t.connectorPedestrians,     desc: t.connectorPedestriansDesc,     dashed: false },
  { emoji: '🅿️', label: t.connectorParking,         desc: t.connectorParkingDesc,         dashed: false },
  { emoji: '🏠', label: t.connectorRent,            desc: t.connectorRentDesc,            dashed: false },
  { emoji: '🔒', label: t.connectorCrime,           desc: t.connectorCrimeDesc,           dashed: false },
  { emoji: '🗑️', label: t.connectorWasteSchedule,  desc: t.connectorWasteScheduleDesc,   dashed: false },
  { emoji: '♻️', label: t.connectorRecyclingPoints, desc: t.connectorRecyclingPointsDesc, dashed: false },
  { emoji: '🚛', label: t.connectorMobileRecycling, desc: t.connectorMobileRecyclingDesc, dashed: false },
  { emoji: '📊', label: t.connectorRecyclingStats,  desc: t.connectorRecyclingStatsDesc,  dashed: false },
  { emoji: '🗳️', label: t.connectorVoting,          desc: t.connectorVotingDesc,          dashed: false },
  { emoji: '🏊', label: t.connectorBadi,            desc: t.connectorBadiDesc,            dashed: false },
  { emoji: '🔍', label: t.connectorWebSearch,       desc: t.connectorWebSearchDesc,       dashed: true  },
];

const techLayers = [
  { emoji: '🌐', label: t.techFrontend,  tech: 'Astro + Tailwind · Open WebUI', desc: t.techFrontendDesc },
  { emoji: '🔑', label: t.techAuth,      tech: 'ZITADEL',                        desc: t.techAuthDesc },
  { emoji: '⚡', label: t.techAPI,       tech: 'FastAPI (Python)',                desc: t.techAPIDesc },
  { emoji: '🧠', label: t.techAI,        tech: 'Apertus 70B · Infomaniak',       desc: t.techAIDesc },
  { emoji: '📚', label: t.techKnowledge, tech: 'ChromaDB',                        desc: t.techKnowledgeDesc },
  { emoji: '🏔️', label: t.techHosting,   tech: 'Infomaniak · Zürich',             desc: t.techHostingDesc },
];
---

<section id="how" class="py-20 sm:py-28 bg-gray-50/50">
  <div class="max-w-6xl mx-auto px-4 sm:px-6">

    <!-- Header -->
    <div class="max-w-3xl mx-auto text-center mb-14" data-animate>
      <p class="font-mono text-xs text-zurich-blue tracking-widest uppercase mb-4">{t.howTagline}</p>
      <h2 class="text-3xl sm:text-4xl md:text-5xl font-extrabold tracking-tight mb-4 text-zurich-dark">
        {t.howTitle}
      </h2>
      <p class="text-zurich-gray text-lg">{t.howSubtitle}</p>
    </div>

    <div class="max-w-4xl mx-auto space-y-14" data-animate>

      <!-- 3-step process -->
      <div>
        <p class="font-mono text-xs text-zurich-blue tracking-widest uppercase mb-6 text-center font-semibold">{t.howProcessTitle}</p>
        <div class="grid grid-cols-1 md:grid-cols-3 gap-4 max-w-3xl mx-auto">
          {steps.map((s, i) => (
            <div class="relative flex flex-col items-center text-center">
              {i < 2 && (
                <span class="hidden md:block absolute top-4 -right-2 text-zurich-gray/30 text-xl leading-none select-none">›</span>
              )}
              <div class="w-10 h-10 rounded-full border-2 border-zurich-blue/20 bg-zurich-blue/5 flex items-center justify-center mb-3 text-sm font-bold text-zurich-blue">
                {s.num}
              </div>
              <h4 class="text-sm font-bold text-zurich-dark mb-1.5">{s.title}</h4>
              <p class="text-xs text-zurich-gray leading-relaxed">{s.desc}</p>
            </div>
          ))}
        </div>
      </div>

      <!-- Layer 1: Brain -->
      <div class="text-center">
        <div class="flex items-center gap-2 mb-2 justify-center">
          <span class="text-lg" aria-hidden="true">🧠</span>
          <h3 class="font-mono text-xs text-zurich-blue tracking-widest uppercase font-semibold">{t.howLayer1Title}</h3>
        </div>
        <p class="text-sm text-zurich-gray max-w-2xl mx-auto">{t.howLayer1Desc}</p>
      </div>

      <!-- Layer 2: Knowledge Base -->
      <div>
        <div class="flex items-center gap-2 mb-2 justify-center">
          <span class="text-lg" aria-hidden="true">📚</span>
          <h3 class="font-mono text-xs text-zurich-blue tracking-widest uppercase font-semibold">{t.howLayer2Title}</h3>
        </div>
        <p class="text-sm text-zurich-gray text-center mb-6">{t.howLayer2Desc}</p>

        <div class="flex flex-wrap justify-center gap-2 max-w-3xl mx-auto">
          {knowledgeTopics.map(kb => (
            <span
              title={kb.desc}
              class="inline-flex items-center gap-2 bg-white border border-zurich-border rounded-full px-3 py-1.5 hover:border-zurich-blue/30 hover:shadow-sm transition-all duration-200 cursor-default"
            >
              <span class="text-base" aria-hidden="true">{kb.emoji}</span>
              <span class="text-xs font-medium text-zurich-dark whitespace-nowrap">{kb.label}</span>
              <span class="text-[10px] font-mono text-zurich-gray">{kb.count}</span>
            </span>
          ))}
        </div>
      </div>

      <!-- Layer 3: Live Connectors -->
      <div>
        <div class="flex items-center gap-2 mb-2 justify-center">
          <span class="text-lg" aria-hidden="true">⚡</span>
          <h3 class="font-mono text-xs text-zurich-blue tracking-widest uppercase font-semibold">{t.howLayer3Title}</h3>
        </div>
        <p class="text-sm text-zurich-gray text-center mb-6">{t.howLayer3Desc}</p>

        <div class="flex flex-wrap justify-center gap-2 max-w-4xl mx-auto">
          {connectors.map(c => (
            <span
              title={c.desc}
              class:list={[
                'inline-flex items-center gap-2 bg-white rounded-full px-3 py-1.5 hover:border-zurich-blue/30 hover:shadow-sm transition-all duration-200 cursor-default',
                c.dashed ? 'border border-dashed border-zurich-gray/40' : 'border border-zurich-border',
              ]}
            >
              <span class="text-base" aria-hidden="true">{c.emoji}</span>
              <span class="text-xs font-medium text-zurich-dark whitespace-nowrap">{c.label}</span>
            </span>
          ))}
        </div>

        <div class="text-center mt-3">
          <a href={suggestMailto} class="text-xs text-zurich-gray hover:text-zurich-blue transition-colors">
            {t.connectorSuggest}
          </a>
        </div>
      </div>

      <!-- Collapsible tech stack -->
      <div class="text-center" id="tech">
        <details class="group">
          <summary class="inline-flex items-center gap-1.5 text-sm text-zurich-blue hover:underline font-medium cursor-pointer list-none">
            {t.howTechDetails}
            <svg class="h-4 w-4 transition-transform duration-200 group-open:rotate-180" viewBox="0 0 16 16" fill="none" aria-hidden="true">
              <path d="M4 6l4 4 4-4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
            </svg>
          </summary>

          <div class="mt-6 max-w-2xl mx-auto space-y-3 text-left">
            <p class="font-mono text-xs text-zurich-blue tracking-widest uppercase mb-4 text-center">{t.techTagline}</p>
            {techLayers.map(layer => (
              <div class="bg-white border border-zurich-border rounded-xl px-5 py-4 hover:border-zurich-blue/30 hover:shadow-sm transition-all duration-200">
                <div class="flex items-start gap-4">
                  <div class="w-8 h-8 rounded-lg bg-zurich-blue/10 flex items-center justify-center flex-shrink-0 mt-0.5 text-sm">
                    {layer.emoji}
                  </div>
                  <div class="flex-1 min-w-0">
                    <div class="flex items-center gap-2 mb-0.5">
                      <span class="font-mono text-[10px] text-zurich-blue uppercase tracking-wider font-semibold">{layer.label}</span>
                      <span class="text-[11px] text-zurich-gray font-mono">· {layer.tech}</span>
                    </div>
                    <p class="text-sm text-zurich-gray leading-relaxed">{layer.desc}</p>
                  </div>
                </div>
              </div>
            ))}

            <div class="text-center pt-4">
              <span class="inline-flex items-center gap-2 bg-zurich-blue/5 border border-zurich-blue/20 rounded-full px-4 py-2 text-sm text-zurich-blue font-medium">
                {t.techOpenSource}
              </span>
            </div>
          </div>
        </details>
      </div>

    </div>
  </div>
</section>
