---
import SectionHeader from '../ui/SectionHeader.astro';
import type { TranslationSchema } from '../../i18n/translations/de';

interface Props {
  t: TranslationSchema;
}

const { t } = Astro.props;

const suggestMailto = `mailto:hello@buenzli.space?subject=${encodeURIComponent('Connector Suggestion - buenzli.space')}&body=${encodeURIComponent("Hi Buenzli Team,\n\nI'd like to suggest a new connector:\n\nData source: \nWhat it would do: \nWhy it's useful: \n\nBest regards")}`;

const steps = [
  { num: '1', title: t.howStep1Title, desc: t.howStep1Desc },
  { num: '2', title: t.howStep2Title, desc: t.howStep2Desc },
  { num: '3', title: t.howStep3Title, desc: t.howStep3Desc },
];

const knowledgeTopics = [
  { emoji: '🏠', label: t.kbRenting,       count: t.kbRentingCount,        desc: t.kbRentingDesc },
  { emoji: '🏛️', label: t.kbGovernment,    count: t.kbGovernmentCount,     desc: t.kbGovernmentDesc },
  { emoji: '📰', label: t.kbNews,           count: t.kbNewsCount,           desc: t.kbNewsDesc },
  { emoji: '🍽️', label: t.kbFood,           count: t.kbFoodCount,           desc: t.kbFoodDesc },
  { emoji: '📂', label: t.kbOpenData,       count: t.kbOpenDataCount,       desc: t.kbOpenDataDesc },
  { emoji: '🏘️', label: t.kbNeighbourhoods, count: t.kbNeighbourhoodsCount, desc: t.kbNeighbourhoodsDesc },
  { emoji: '🧳', label: t.kbExpat,          count: t.kbExpatCount,          desc: t.kbExpatDesc },
  { emoji: '⚖️', label: t.kbSwissLaw,       count: t.kbSwissLawCount,       desc: t.kbSwissLawDesc },
];

const connectors = [
  { emoji: '🚃', label: t.connectorDepartures,     desc: t.connectorDeparturesDesc },
  { emoji: '🗺️', label: t.connectorConnections,    desc: t.connectorConnectionsDesc },
  { emoji: '🌦️', label: t.connectorWeather,         desc: t.connectorWeatherDesc },
  { emoji: '💨', label: t.connectorAirQuality,      desc: t.connectorAirQualityDesc },
  { emoji: '🚰', label: t.connectorDrinkingWater,   desc: t.connectorDrinkingWaterDesc },
  { emoji: '🌡️', label: t.connectorWaterTemp,       desc: t.connectorWaterTempDesc },
  { emoji: '⚡', label: t.connectorElectricity,     desc: t.connectorElectricityDesc },
  { emoji: '📍', label: t.connectorPOI,             desc: t.connectorPOIDesc },
  { emoji: '🍽️', label: t.connectorVenues,          desc: t.connectorVenuesDesc },
  { emoji: '🎪', label: t.connectorEvents,          desc: t.connectorEventsDesc },
  { emoji: '🚶', label: t.connectorPedestrians,     desc: t.connectorPedestriansDesc },
  { emoji: '🅿️', label: t.connectorParking,         desc: t.connectorParkingDesc },
  { emoji: '🏠', label: t.connectorRent,            desc: t.connectorRentDesc },
  { emoji: '🔒', label: t.connectorCrime,           desc: t.connectorCrimeDesc },
  { emoji: '🗑️', label: t.connectorWasteSchedule,  desc: t.connectorWasteScheduleDesc },
  { emoji: '♻️', label: t.connectorRecyclingPoints, desc: t.connectorRecyclingPointsDesc },
  { emoji: '🚛', label: t.connectorMobileRecycling, desc: t.connectorMobileRecyclingDesc },
  { emoji: '📊', label: t.connectorRecyclingStats,  desc: t.connectorRecyclingStatsDesc },
  { emoji: '🗳️', label: t.connectorVoting,          desc: t.connectorVotingDesc },
  { emoji: '🏊', label: t.connectorBadi,            desc: t.connectorBadiDesc },
  { emoji: '🔍', label: t.connectorWebSearch,       desc: t.connectorWebSearchDesc, dashed: true },
];
---

<section id="how" class="py-20 sm:py-28 bg-zh-black-5">
  <div class="max-w-6xl mx-auto px-4 sm:px-6">

    <!-- Header -->
    <div class="mb-14" data-animate>
      <SectionHeader
        eyebrow={t.howTagline}
        heading={t.howTitle}
        subtext={t.howSubtitle}
      />
    </div>

    <!-- 3 Steps -->
    <div class="grid grid-cols-1 sm:grid-cols-3 gap-4 max-w-3xl mx-auto mb-16" data-animate>
      {steps.map((s, i) => (
        <div class="relative bg-white border border-zurich-border rounded-xl p-5 text-center hover:border-zurich-blue/30 hover:shadow-short transition-all duration-200">
          {i < 2 && (
            <span class="hidden sm:block absolute top-1/2 -right-3 -translate-y-1/2 text-zurich-gray/30 text-xl select-none z-10">›</span>
          )}
          <div class="w-9 h-9 rounded-full border-2 border-zurich-blue/20 bg-zurich-blue/5 flex items-center justify-center mx-auto mb-3 text-sm font-bold text-zurich-blue">
            {s.num}
          </div>
          <h4 class="text-sm font-bold text-zurich-dark mb-1.5">{s.title}</h4>
          <p class="text-xs text-zurich-gray leading-relaxed">{s.desc}</p>
        </div>
      ))}
    </div>

    <!-- Knowledge + Connectors -->
    <div class="grid grid-cols-1 lg:grid-cols-2 gap-6" data-animate>

      <!-- Knowledge Base -->
      <div class="bg-white border border-zurich-border rounded-2xl overflow-hidden">
        <div class="px-5 py-4 border-b border-zurich-border flex items-center gap-2">
          <span class="text-base" aria-hidden="true">📚</span>
          <h3 class="font-semibold text-sm text-zurich-dark">{t.howLayer2Title}</h3>
        </div>
        <ul class="divide-y divide-zurich-border">
          {knowledgeTopics.map(kb => (
            <li class="flex items-center gap-3 px-5 py-3 hover:bg-zh-black-5 transition-colors duration-150 cursor-default group" title={kb.desc}>
              <span class="text-base w-6 text-center shrink-0" aria-hidden="true">{kb.emoji}</span>
              <span class="text-sm text-zurich-dark flex-1 group-hover:text-zurich-blue transition-colors">{kb.label}</span>
              <span class="text-xs font-mono text-zurich-gray tabular-nums">{kb.count}</span>
            </li>
          ))}
        </ul>
      </div>

      <!-- Live Connectors -->
      <div class="bg-white border border-zurich-border rounded-2xl overflow-hidden">
        <div class="px-5 py-4 border-b border-zurich-border flex items-center gap-2">
          <span class="text-base" aria-hidden="true">⚡</span>
          <h3 class="font-semibold text-sm text-zurich-dark">{t.howLayer3Title}</h3>
        </div>
        <div class="grid grid-cols-3 divide-x divide-y divide-zurich-border">
          {connectors.map(c => (
            <div
              title={c.desc}
              class:list={[
                'flex flex-col items-center gap-1.5 px-2 py-3 hover:bg-zh-black-5 transition-colors duration-150 cursor-default text-center',
                c.dashed ? 'opacity-50' : '',
              ]}
            >
              <span class="text-xl leading-none" aria-hidden="true">{c.emoji}</span>
              <span class="text-[10px] text-zurich-gray leading-tight">{c.label}</span>
            </div>
          ))}
        </div>
        <div class="px-5 py-3 border-t border-zurich-border">
          <a href={suggestMailto} class="text-xs text-zurich-gray hover:text-zurich-blue transition-colors">
            {t.connectorSuggest} →
          </a>
        </div>
      </div>

    </div>
  </div>
</section>
