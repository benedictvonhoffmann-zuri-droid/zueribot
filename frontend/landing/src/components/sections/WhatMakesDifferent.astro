---
import SectionWrapper from '../ui/SectionWrapper.astro';
import type { TranslationSchema } from '../../i18n/translations/de';

interface Props {
  t: TranslationSchema;
}

const { t } = Astro.props;
const { different } = t;
---

<SectionWrapper id="different" bg="off-white">
  <div class="text-center mb-14" data-animate>
    <p class="section-label mb-3">02</p>
    <h2 class="section-heading text-zurich-dark mb-4">{different.heading}</h2>
    <p class="text-zurich-gray text-lg max-w-xl mx-auto">{different.subline}</p>
  </div>

  <div class="grid sm:grid-cols-2 gap-5" data-animate-stagger>
    {different.cards.map((card, i) => (
      <div class="different-card group relative p-7 rounded-2xl bg-white border border-zurich-border hover:border-transparent transition-all duration-300 hover:shadow-xl hover:-translate-y-0.5 overflow-hidden">
        <!-- Gradient blob on hover -->
        <div class="different-card-glow absolute -top-12 -right-12 w-40 h-40 rounded-full opacity-0 group-hover:opacity-100 transition-opacity duration-500 pointer-events-none"></div>

        <span class="text-3xl mb-5 block">{card.icon}</span>
        <h3 class="font-bold text-zurich-dark text-lg mb-3 group-hover:text-zurich-blue transition-colors duration-200">
          {card.title}
        </h3>
        <p class="text-zurich-gray text-sm leading-relaxed">{card.desc}</p>
      </div>
    ))}
  </div>
</SectionWrapper>

<style>
  .different-card-glow {
    background: radial-gradient(circle, rgba(0,100,180,0.12) 0%, transparent 70%);
    filter: blur(20px);
  }
</style>
