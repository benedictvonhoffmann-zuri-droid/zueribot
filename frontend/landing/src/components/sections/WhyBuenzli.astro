---
import SectionWrapper from '../ui/SectionWrapper.astro';
import type { TranslationSchema } from '../../i18n/translations/de';

interface Props {
  t: TranslationSchema;
}

const { t } = Astro.props;
const { why } = t;
---

<SectionWrapper id="why" bg="white">
  <div class="text-center mb-14" data-animate>
    <p class="section-label mb-3">01</p>
    <h2 class="section-heading text-zurich-dark">{why.heading}</h2>
  </div>

  <div class="grid md:grid-cols-2 gap-6 max-w-4xl mx-auto" data-animate-stagger>
    <!-- Problem -->
    <div class="why-card why-problem group relative p-8 rounded-2xl overflow-hidden border border-red-100 bg-red-50/50 hover:shadow-lg transition-all duration-300">
      <div class="absolute top-0 left-0 right-0 h-0.5 bg-gradient-to-r from-transparent via-red-300 to-transparent"></div>
      <div class="flex items-center gap-3 mb-5">
        <span class="text-2xl">😤</span>
        <h3 class="font-bold text-zurich-dark text-base">{why.problemHeading}</h3>
      </div>
      <p class="text-zurich-gray text-sm leading-relaxed">{why.problemText}</p>
    </div>

    <!-- Solution -->
    <div class="why-card why-solution group relative p-8 rounded-2xl overflow-hidden border border-zurich-blue/15 bg-zurich-blue-light/40 hover:shadow-lg transition-all duration-300">
      <div class="absolute top-0 left-0 right-0 h-0.5 bg-gradient-to-r from-transparent via-zurich-blue/50 to-transparent"></div>
      <div class="flex items-center gap-3 mb-5">
        <span class="text-2xl">✨</span>
        <h3 class="font-bold text-zurich-dark text-base">{why.solutionHeading}</h3>
      </div>
      <p class="text-zurich-gray text-sm leading-relaxed">{why.solutionText}</p>
    </div>
  </div>
</SectionWrapper>
