---
import SectionHeader from '../ui/SectionHeader.astro';
import type { TranslationSchema } from '../../i18n/translations/de';

interface Props {
  t: TranslationSchema;
}

const { t } = Astro.props;

const comparisons = [
  { them: t.privacyThem1, us: t.privacyUs1 },
  { them: t.privacyThem2, us: t.privacyUs2 },
  { them: t.privacyThem3, us: t.privacyUs3 },
  { them: t.privacyThem4, us: t.privacyUs4 },
  { them: t.privacyThem5, us: t.privacyUs5 },
];
---

<section id="privacy" class="relative py-20 sm:py-28 overflow-hidden bg-zurich-blue">

  <!-- Subtle dot grid -->
  <div
    class="absolute inset-0 pointer-events-none opacity-10"
    style="background-image: radial-gradient(rgba(255,255,255,0.4) 1px, transparent 1px); background-size: 28px 28px;"
  ></div>

  <div class="max-w-6xl mx-auto px-4 sm:px-6 relative z-10">

    <!-- Header -->
    <div class="mb-14" data-animate>
      <SectionHeader eyebrow={t.privacyTagline} heading={t.privacyTitle1} theme="dark">
        <span slot="heading">
          {t.privacyTitle1}
          <br />
          <span class="text-white/60">{t.privacyTitle2}</span>
        </span>
      </SectionHeader>
      <div class="text-center mt-4">
        <p class="text-xl font-bold text-white mb-2">{t.privacyPledge}</p>
        <p class="text-white/70">{t.privacySubtitle}</p>

        <!-- Sovereign badge -->
        <div class="mt-6 inline-flex items-center gap-2 bg-white/15 border border-white/30 rounded-full px-4 py-2 text-sm text-white font-medium">
          <svg width="14" height="14" viewBox="0 0 14 14" fill="none" aria-hidden="true">
            <path d="M7 1L2 3.5V7c0 3 2.5 5 5 5.5C12 12 14 9 14 7V3.5L7 1z" fill="none" stroke="white" stroke-width="1.5" stroke-linejoin="round"/>
          </svg>
          <span class="font-semibold">{t.featureSovereign}</span>
          — {t.featureSovereignDesc}
        </div>
      </div>
    </div>

    <!-- Comparison table -->
    <div class="max-w-2xl mx-auto" data-animate>
      <div class="bg-white/10 border border-white/20 rounded-xl overflow-hidden backdrop-blur-sm">

        <!-- Table header -->
        <div class="grid grid-cols-2 border-b border-white/20">
          <div class="px-5 py-3 text-xs font-mono text-white/50 uppercase tracking-wider">
            {t.privacyThemLabel}
          </div>
          <div class="px-5 py-3 text-xs font-mono text-white uppercase tracking-wider border-l border-white/20 flex items-center gap-1.5">
            <img src="/zh-lion.svg" alt="" aria-hidden="true" class="w-3 h-3 brightness-0 invert opacity-80" />
            {t.privacyUsLabel}
          </div>
        </div>

        <!-- Comparison rows -->
        {comparisons.map((row, i) => (
          <div class:list={['grid grid-cols-2', i < comparisons.length - 1 ? 'border-b border-white/15' : '']}>
            <div class="px-5 py-3.5 flex items-center gap-2">
              <svg width="14" height="14" viewBox="0 0 14 14" fill="none" aria-hidden="true" class="shrink-0">
                <path d="M3 3l8 8M11 3l-8 8" stroke="rgba(255,180,180,0.7)" stroke-width="1.5" stroke-linecap="round"/>
              </svg>
              <span class="text-sm text-white/55">{row.them}</span>
            </div>
            <div class="px-5 py-3.5 border-l border-white/15 bg-white/10 flex items-center gap-2">
              <svg width="14" height="14" viewBox="0 0 14 14" fill="none" aria-hidden="true" class="shrink-0">
                <path d="M2 7l4 4 6-7" stroke="rgba(255,255,255,0.9)" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
              </svg>
              <span class="text-sm text-white font-semibold">{row.us}</span>
            </div>
          </div>
        ))}

      </div>
    </div>

  </div>
</section>
