---
import SectionWrapper from '../ui/SectionWrapper.astro';
import type { TranslationSchema } from '../../i18n/translations/de';

interface Props {
  t: TranslationSchema;
}

const { t } = Astro.props;
const { privacy } = t;
---

<SectionWrapper id="privacy" bg="off-white">
  <div class="text-center mb-14">
    <h2 class="text-3xl sm:text-5xl font-bold text-zurich-dark mb-4">{privacy.heading}</h2>
    <p class="text-zurich-gray text-lg max-w-2xl mx-auto">{privacy.subline}</p>
  </div>
  <div class="grid sm:grid-cols-2 gap-6 max-w-4xl mx-auto">
    {privacy.pillars.map(pillar => (
      <div class="bg-white rounded-2xl p-7 border border-zurich-border flex gap-5">
        <span class="text-3xl shrink-0 mt-1">{pillar.icon}</span>
        <div>
          <h3 class="font-bold text-zurich-dark text-lg mb-2">{pillar.title}</h3>
          <p class="text-zurich-gray text-sm leading-relaxed">{pillar.desc}</p>
        </div>
      </div>
    ))}
  </div>
</SectionWrapper>
