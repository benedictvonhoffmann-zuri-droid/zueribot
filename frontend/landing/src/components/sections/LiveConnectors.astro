---
import SectionWrapper from '../ui/SectionWrapper.astro';
import ConnectorCard from '../ui/ConnectorCard.astro';
import type { TranslationSchema } from '../../i18n/translations/de';

interface Props {
  t: TranslationSchema;
}

const { t } = Astro.props;
const { connectors } = t;
---

<SectionWrapper id="connectors" bg="white">
  <div class="text-center mb-14">
    <h2 class="text-3xl sm:text-5xl font-bold text-zurich-dark mb-4">{connectors.heading}</h2>
    <p class="text-zurich-gray text-lg max-w-2xl mx-auto">{connectors.subline}</p>
  </div>
  <div class="grid grid-cols-2 sm:grid-cols-3 lg:grid-cols-4 gap-4">
    {connectors.items.map(item => (
      <ConnectorCard icon={item.icon} name={item.name} desc={item.desc} />
    ))}
  </div>
</SectionWrapper>
