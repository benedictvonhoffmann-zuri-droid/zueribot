---
import type { TranslationSchema } from '../../i18n/translations/de';

interface Props {
  t: TranslationSchema;
}

const { t } = Astro.props;

const betaHref = `mailto:hello@buenzli.space?subject=${encodeURIComponent('Beta Test Request - buenzli.space')}&body=${encodeURIComponent('Hi Buenzli Team,\n\nI would like to beta test buenzli.space!\n\nLinkedIn profile: \nWhy I want to test: \nWhat I would use Bünzli AI for: \n\nBest regards')}`;
const collabHref = `mailto:hello@buenzli.space?subject=${encodeURIComponent('Collaboration Inquiry - buenzli.space')}&body=${encodeURIComponent('Hi Buenzli Team,\n\nI would like to collaborate on buenzli.space!\n\nLinkedIn profile: \nWhy I want to collaborate: \nSkills I bring: \n\nBest regards')}`;

const badges = [t.communityBadge1, t.communityBadge2, t.communityBadge3];

const roadmap = [
  { phase: t.roadmapPhase1, desc: t.roadmapPhase1Desc, status: t.roadmapPhase1Status, active: true },
  { phase: t.roadmapPhase2, desc: t.roadmapPhase2Desc, status: t.roadmapPhase2Status, active: false },
  { phase: t.roadmapPhase3, desc: t.roadmapPhase3Desc, status: t.roadmapPhase3Status, active: false },
];

const activeIndex = roadmap.findIndex(r => r.active);
const progressPercent = ((activeIndex + 0.5) / roadmap.length) * 100;

const teaserPlaceholders = [
  t.heroTeaserPlaceholder1,
  t.heroTeaserPlaceholder2,
  t.heroTeaserPlaceholder3,
  t.heroTeaserPlaceholder4,
];
---

<section id="community" class="py-20 sm:py-28 bg-white">
  <div class="max-w-6xl mx-auto px-4 sm:px-6">
    <div class="max-w-5xl mx-auto">

      <!-- Header + CTAs -->
      <div class="grid md:grid-cols-2 gap-12 md:gap-16 items-center mb-20" data-animate>
        <div>
          <img src="/zh-lion.svg" alt="" aria-hidden="true" class="w-10 h-10 mb-6 opacity-80" />
          <h2 class="text-3xl sm:text-4xl font-extrabold tracking-tight mb-4 text-zurich-dark">
            {t.communityTitle1}
            <br />
            <span class="text-gradient">{t.communityTitle2}</span>
          </h2>
          <p class="text-zurich-gray leading-relaxed mb-6">{t.communityDesc}</p>
          <div class="flex flex-wrap gap-2">
            {badges.map(badge => (
              <span class="inline-flex items-center text-xs font-medium bg-zurich-blue/10 text-zurich-blue px-3 py-1.5 rounded-full border border-zurich-blue/20">
                {badge}
              </span>
            ))}
          </div>
        </div>

        <div class="space-y-4">
          <div class="bg-white border border-zurich-border rounded-xl p-6 shadow-sm">
            <h3 class="font-bold text-zurich-dark mb-2">{t.communityBetaTitle}</h3>
            <p class="text-sm text-zurich-gray mb-4">{t.communityBetaDesc}</p>
            <a
              href={betaHref}
              class="inline-flex items-center gap-2 px-5 py-2.5 rounded-lg font-semibold text-sm bg-zurich-blue text-white hover:bg-zurich-blue-dark transition-colors duration-150"
            >
              {t.communityBetaCta}
              <svg width="14" height="14" viewBox="0 0 14 14" fill="none" aria-hidden="true">
                <path d="M2.5 7h9M8 3.5l3.5 3.5L8 10.5" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
              </svg>
            </a>
          </div>

          <div class="bg-white border border-zurich-border rounded-xl p-6 shadow-sm">
            <h3 class="font-bold text-zurich-dark mb-2">{t.communityCollabTitle}</h3>
            <p class="text-sm text-zurich-gray mb-4">{t.communityCollabDesc}</p>
            <a
              href={collabHref}
              class="inline-flex items-center gap-2 px-5 py-2.5 rounded-lg font-semibold text-sm border border-zurich-blue text-zurich-blue hover:bg-zurich-blue/5 transition-colors duration-150"
            >
              {t.communityCollabCta}
            </a>
          </div>
        </div>
      </div>

      <!-- Roadmap -->
      <div class="max-w-3xl mx-auto" data-animate>
        <div class="text-center mb-8">
          <h3 class="text-2xl sm:text-3xl font-extrabold tracking-tight text-zurich-dark mb-2">{t.roadmapTitle}</h3>
          <p class="text-zurich-gray text-sm">{t.roadmapSubtitle}</p>
        </div>

        <!-- Progress bar -->
        <div class="h-1 bg-zurich-border rounded-full mb-8 overflow-hidden">
          <div class="h-1 bg-zurich-blue rounded-full transition-all duration-1000" style={`width: ${progressPercent}%`}></div>
        </div>

        <!-- Phase cards -->
        <div class="grid sm:grid-cols-3 gap-4 mb-8" data-animate-stagger>
          {roadmap.map(r => (
            <div class:list={[
              'relative rounded-xl border p-5 transition-all duration-300',
              r.active ? 'border-zurich-blue bg-zurich-blue/[0.04] shadow-sm' : 'border-zurich-border bg-white',
            ]}>
              {r.active && (
                <span class="absolute -top-2.5 left-4 bg-zurich-blue text-white text-[10px] font-semibold px-2 py-0.5 rounded-full">
                  Live
                </span>
              )}
              <span class="text-[10px] font-mono text-zurich-gray uppercase tracking-wider block mb-2">{r.status}</span>
              <h4 class="font-bold text-sm text-zurich-dark mb-1">{r.phase}</h4>
              <p class="text-xs text-zurich-gray leading-relaxed">{r.desc}</p>
            </div>
          ))}
        </div>

        <p class="text-center text-xs text-zurich-gray mb-10">{t.roadmapCommunityNote}</p>
      </div>

      <!-- Final CTA -->
      <div class="text-center" data-animate>
        <p class="text-lg font-bold text-zurich-dark mb-1">{t.footerCtaTitle}</p>
        <p class="text-sm text-zurich-gray mb-5">{t.footerCtaDesc}</p>
        <div class="flex justify-center mb-4">
          <a
            href={betaHref}
            class="group inline-flex items-center gap-3 bg-zurich-blue/[0.06] border border-zurich-blue/20 rounded-xl px-4 py-3 hover:bg-zurich-blue/10 hover:shadow-md transition-all duration-200 max-w-md w-full"
          >
            <svg width="16" height="16" viewBox="0 0 16 16" fill="none" aria-hidden="true" class="text-zurich-blue/60 flex-shrink-0">
              <circle cx="8" cy="8" r="6.5" stroke="currentColor" stroke-width="1.2"/>
              <path d="M5 8h6M8 5l3 3-3 3" stroke="currentColor" stroke-width="1.2" stroke-linecap="round" stroke-linejoin="round"/>
            </svg>
            <span id="teaser-text" class="text-sm text-zurich-gray transition-opacity duration-200"></span>
            <span class="ml-auto text-xs font-medium text-zurich-blue opacity-0 group-hover:opacity-100 transition-opacity whitespace-nowrap">
              {t.heroTeaserLabel} →
            </span>
          </a>
        </div>
        <a href={betaHref} class="text-xs text-zurich-blue/80 hover:text-zurich-blue hover:underline font-medium">
          {t.communityBetaCta} →
        </a>
      </div>

    </div>
  </div>
</section>

<script define:vars={{ teaserPlaceholders }}>
  const el = document.getElementById('teaser-text');
  if (el) {
    let idx = 0;
    el.textContent = teaserPlaceholders[0];
    setInterval(() => {
      el.style.opacity = '0';
      setTimeout(() => {
        idx = (idx + 1) % teaserPlaceholders.length;
        el.textContent = teaserPlaceholders[idx];
        el.style.opacity = '1';
      }, 200);
    }, 3000);
    el.style.transition = 'opacity 0.2s ease';
  }
</script>
