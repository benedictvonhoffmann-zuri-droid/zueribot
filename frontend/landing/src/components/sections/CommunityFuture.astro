---
import SectionWrapper from '../ui/SectionWrapper.astro';
import type { TranslationSchema } from '../../i18n/translations/de';

interface Props {
  t: TranslationSchema;
}

const { t } = Astro.props;
const { community } = t;
---

<SectionWrapper id="community" bg="off-white">
  <div class="text-center mb-14" data-animate>
    <p class="section-label mb-3">08</p>
    <h2 class="section-heading text-zurich-dark mb-4">{community.heading}</h2>
    <p class="text-zurich-gray text-lg max-w-xl mx-auto">{community.subline}</p>
  </div>

  <div class="grid sm:grid-cols-2 gap-5 max-w-4xl mx-auto" data-animate-stagger>
    {community.items.map(item => (
      <div class="group relative p-7 rounded-2xl bg-white border border-zurich-border hover:border-tram-green/40 hover:shadow-lg transition-all duration-300 hover:-translate-y-0.5 overflow-hidden">
        <div class="absolute top-0 left-0 right-0 h-0.5 bg-gradient-to-r from-transparent via-tram-green/40 to-transparent opacity-0 group-hover:opacity-100 transition-opacity duration-300"></div>
        <span class="text-2xl mb-4 block group-hover:scale-110 transition-transform duration-200">{item.icon}</span>
        <h3 class="font-bold text-zurich-dark text-base mb-2">{item.title}</h3>
        <p class="text-zurich-gray text-sm leading-relaxed">{item.desc}</p>
      </div>
    ))}
  </div>
</SectionWrapper>
