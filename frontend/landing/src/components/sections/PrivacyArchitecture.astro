---
import type { TranslationSchema } from '../../i18n/translations/de';

interface Props {
  t: TranslationSchema;
}

const { t } = Astro.props;

const hops = [
  { label: t.privDiagramYou,   icon: '🧑' },
  { label: t.privDiagramISP,   icon: '🌐' },
  { label: t.privDiagramHost,  icon: '🏢' },
  { label: t.privDiagramModel, icon: '🧠' },
];

const pillars = [
  { title: t.privPillar1Title, body: t.privPillar1Body, link: t.privPillar1Link, href: 'https://publicai.co/' },
  { title: t.privPillar2Title, body: t.privPillar2Body, link: t.privPillar2Link, href: 'https://www.infomaniak.com/en' },
  { title: t.privPillar3Title, body: t.privPillar3Body, link: t.privPillar3Link, href: 'https://www.edoeb.admin.ch/en' },
];
---

<section id="privacy" class="relative py-20 sm:py-28 overflow-hidden bg-zurich-blue text-white">

  <!-- Subtle dot grid -->
  <div
    class="absolute inset-0 pointer-events-none opacity-10"
    style="background-image: radial-gradient(rgba(255,255,255,0.4) 1px, transparent 1px); background-size: 28px 28px;"
  ></div>

  <div class="relative max-w-6xl mx-auto px-4 sm:px-6">

    <!-- Header -->
    <div class="mb-14 text-center max-w-3xl mx-auto" data-animate>
      <p class="mb-4">
        <span class="inline-block bg-white px-2.5 py-1 font-mono text-xs tracking-widest uppercase text-tram-green -rotate-1">
          {t.privEyebrow}
        </span>
      </p>
      <h2 class="text-3xl sm:text-4xl md:text-5xl font-extrabold tracking-tight mb-4 text-white">
        {t.privHeadline}
      </h2>
      <p class="text-lg text-white/70">{t.privSub}</p>
    </div>

    <!-- Request path diagram — desktop only -->
    <div class="hidden sm:block max-w-4xl mx-auto mb-12" data-animate>
      <div class="bg-white/5 border border-white/80 rounded-md p-6 sm:p-8">
        <div class="flex items-center">
          {hops.map((h, i) => (
            <>
              <div class="flex-1 flex flex-col items-center text-center">
                <div class="w-12 h-12 rounded-full bg-white flex items-center justify-center text-xl mb-2 shadow-sm" aria-hidden="true">
                  {h.icon}
                </div>
                <span class="text-xs font-mono text-white/90 uppercase tracking-wider">{h.label}</span>
              </div>
              {i < hops.length - 1 && (
                <div class="flex items-center justify-center text-white/30 px-2">
                  <svg width="28" height="12" viewBox="0 0 28 12" fill="none" aria-hidden="true">
                    <path d="M1 6h24M21 2l4 4-4 4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
                  </svg>
                </div>
              )}
            </>
          ))}
        </div>
        <p class="text-xs text-white/60 text-center mt-6 max-w-2xl mx-auto leading-relaxed">
          {t.privDiagramCaption}
        </p>
      </div>
    </div>

    <!-- Pillars -->
    <div class="grid md:grid-cols-3 gap-4 mb-12" data-animate>
      {pillars.map((p, i) => (
        <div class="rounded-md p-6 bg-white/5 border border-white/80 hover:bg-white/10 transition-colors">
          <div class="text-[11px] font-mono text-white/60 mb-3 tracking-wider">0{i + 1}</div>
          <h3 class="font-bold text-white mb-2 text-lg">{p.title}</h3>
          <p class="text-sm text-white/80 leading-relaxed mb-4">{p.body}</p>
          <a href={p.href} target="_blank" rel="noopener noreferrer" class="text-xs font-mono text-white/70 hover:text-white underline underline-offset-2">
            {p.link} →
          </a>
        </div>
      ))}
    </div>

    <!-- Zeros strip -->
    <p class="text-center text-sm text-white/70 mb-6" data-animate>
      {t.privZeros}
    </p>

    <!-- Verify — desktop only (F12 is irrelevant on mobile) -->
    <div class="hidden sm:block text-center" data-animate>
      <div class="inline-flex items-center gap-3 bg-white/10 border border-white/20 rounded-full px-5 py-2.5 text-sm">
        <span class="text-[10px] font-mono text-white/60 uppercase tracking-wider">{t.privVerifyLabel}</span>
        <span class="text-white/90">{t.privVerify}</span>
      </div>
    </div>

  </div>
</section>
