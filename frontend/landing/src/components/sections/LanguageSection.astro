---
import SectionWrapper from '../ui/SectionWrapper.astro';
import { LOCALE_META, type Locale } from '../../i18n/locales';
import type { TranslationSchema } from '../../i18n/translations/de';

interface Props {
  t: TranslationSchema;
  currentLang: Locale;
}

const { t, currentLang } = Astro.props;
const { languages } = t;
---

<SectionWrapper id="languages" bg="off-white">
  <div class="text-center mb-14">
    <h2 class="text-3xl sm:text-5xl font-bold text-zurich-dark mb-4">{languages.heading}</h2>
    <p class="text-zurich-gray text-lg max-w-2xl mx-auto">{languages.subline}</p>
  </div>
  <div class="flex flex-wrap justify-center gap-4 max-w-3xl mx-auto">
    {languages.items.map(item => {
      const locale = item.code as Locale;
      const meta = LOCALE_META[locale];
      const isActive = locale === currentLang;
      return (
        <a
          href={`/${locale}/`}
          class:list={[
            'flex items-center gap-3 px-5 py-4 rounded-xl border transition-all duration-200 group',
            isActive
              ? 'border-zurich-blue bg-zurich-blue-light'
              : 'border-zurich-border bg-white hover:border-zurich-blue hover:bg-zurich-blue-light',
          ]}
        >
          <span class="text-2xl">{meta.flag}</span>
          <div>
            <p class:list={['font-semibold text-sm', isActive ? 'text-zurich-blue' : 'text-zurich-dark group-hover:text-zurich-blue']}>
              {item.name}
            </p>
            <p class="text-zurich-gray text-xs">{item.note}</p>
          </div>
        </a>
      );
    })}
  </div>
</SectionWrapper>
