---
interface Props {
  name: string;
  role: string;
  desc: string;
}

const { name, role, desc } = Astro.props;
---

<div class="tech-card group relative p-6 rounded-xl overflow-hidden transition-all duration-300 hover:-translate-y-0.5">
  <!-- Border gradient -->
  <div class="absolute inset-0 rounded-xl border border-white/8 group-hover:border-white/15 transition-colors duration-300"></div>
  <!-- Background -->
  <div class="absolute inset-0 rounded-xl bg-white/4 group-hover:bg-white/7 transition-colors duration-300"></div>
  <!-- Glow on hover -->
  <div class="absolute inset-0 rounded-xl opacity-0 group-hover:opacity-100 transition-opacity duration-300" style="background: radial-gradient(ellipse at 50% 0%, rgba(0,100,180,0.12) 0%, transparent 70%);"></div>

  <div class="relative z-10">
    <p class="text-xs font-semibold uppercase tracking-widest mb-1 text-badi-orange">{role}</p>
    <h3 class="font-bold text-lg text-white mb-2">{name}</h3>
    <p class="text-white/55 text-sm leading-relaxed">{desc}</p>
  </div>
</div>
