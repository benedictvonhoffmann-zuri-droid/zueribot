---
interface Props {
  name: string;
  role: string;
  desc: string;
}

const { name, role, desc } = Astro.props;
---

<div class="p-6 bg-white/10 rounded-xl border border-white/20 hover:bg-white/15 transition-colors duration-150">
  <p class="text-xs font-semibold text-badi-orange uppercase tracking-widest mb-1">{role}</p>
  <h3 class="font-bold text-xl text-white mb-3">{name}</h3>
  <p class="text-white/70 text-sm leading-relaxed">{desc}</p>
</div>
