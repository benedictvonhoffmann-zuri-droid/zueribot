---
interface Props {
  icon: string;
  name: string;
  desc: string;
}

const { icon, name, desc } = Astro.props;
---

<div class="connector-card group relative p-5 rounded-xl border border-zurich-border bg-white hover:border-transparent transition-all duration-300 cursor-default overflow-hidden">
  <!-- Hover gradient -->
  <div class="connector-hover-bg absolute inset-0 opacity-0 group-hover:opacity-100 transition-opacity duration-300 pointer-events-none rounded-xl"></div>

  <div class="relative z-10">
    <span class="text-2xl mb-3 block group-hover:scale-110 transition-transform duration-200">{icon}</span>
    <h3 class="font-semibold text-zurich-dark text-sm mb-1 group-hover:text-zurich-blue transition-colors">{name}</h3>
    <p class="text-zurich-gray text-xs leading-relaxed">{desc}</p>
  </div>
</div>

<style>
  .connector-hover-bg {
    background: linear-gradient(135deg, rgba(0,100,180,0.04) 0%, rgba(0,100,180,0.08) 100%);
    box-shadow:
      inset 0 0 0 1px rgba(0,100,180,0.15),
      0 4px 20px rgba(0,100,180,0.06);
  }
</style>
