---
import { LOCALES, LOCALE_META, type Locale } from '../i18n/locales';

interface Props {
  currentLang: Locale;
}

const { currentLang } = Astro.props;
---

<nav aria-label="Language selection" class="lang-switcher flex items-center gap-0.5">
  {LOCALES.map(locale => (
    <a
      href={`/${locale}/`}
      hreflang={LOCALE_META[locale].htmlLang}
      aria-current={locale === currentLang ? 'page' : undefined}
      title={LOCALE_META[locale].label}
      class:list={[
        'lang-link px-2 py-1 rounded-md text-xs font-semibold transition-all duration-150',
        locale === currentLang ? 'lang-active' : 'lang-inactive',
      ]}
    >
      {locale.toUpperCase()}
    </a>
  ))}
</nav>

<style>
  .lang-active {
    background: rgba(255,255,255,0.15);
    color: white;
  }
  .lang-inactive {
    color: rgba(255,255,255,0.5);
  }
  .lang-inactive:hover {
    background: rgba(255,255,255,0.08);
    color: rgba(255,255,255,0.85);
  }

  :global(.nav-solid) .lang-active {
    background: var(--color-zurich-blue);
    color: white;
  }
  :global(.nav-solid) .lang-inactive {
    color: var(--color-zurich-gray);
  }
  :global(.nav-solid) .lang-inactive:hover {
    background: var(--color-zurich-blue-light);
    color: var(--color-zurich-blue);
  }
</style>
