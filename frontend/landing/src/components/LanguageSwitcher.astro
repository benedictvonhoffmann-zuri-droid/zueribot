---
import { LOCALES, LOCALE_META, type Locale } from '../i18n/locales';

interface Props {
  currentLang: Locale;
}

const { currentLang } = Astro.props;
---

<nav aria-label="Language selection" class="flex items-center gap-1">
  {LOCALES.map(locale => (
    <a
      href={`/${locale}/`}
      hreflang={LOCALE_META[locale].htmlLang}
      aria-current={locale === currentLang ? 'page' : undefined}
      title={LOCALE_META[locale].label}
      class:list={[
        'px-2 py-1 rounded text-sm font-medium transition-colors',
        locale === currentLang
          ? 'bg-zurich-blue text-white'
          : 'text-zurich-gray hover:text-zurich-blue hover:bg-zurich-blue-light',
      ]}
    >
      <span aria-hidden="true">{LOCALE_META[locale].flag}</span>
      <span class="hidden sm:inline ml-1">{LOCALE_META[locale].label}</span>
    </a>
  ))}
</nav>
