---
import '../styles/global.css';
import LanguageSwitcher from '../components/LanguageSwitcher.astro';
import ContactModal from '../components/ContactModal.astro';
import { LOCALE_META, type Locale } from '../i18n/locales';
import type { TranslationSchema } from '../i18n/translations/de';

interface Props {
  lang: Locale;
  t: TranslationSchema;
}

const { lang, t } = Astro.props;
const htmlLang = LOCALE_META[lang].htmlLang;
const canonicalUrl = `https://buenzli.space/${lang}/`;

const navLinks = [
  { label: t.navBoard,   href: '#board' },
  { label: t.navDay,     href: '#day' },
  { label: t.navCompare, href: '#compare' },
  { label: t.navPrivacy, href: '#privacy' },
  { label: t.navOpen,    href: '#open' },
];
---

<!doctype html>
<html lang={htmlLang} class="scroll-smooth">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{t.metaTitle}</title>
    <meta name="description" content={t.metaDescription} />
    <link rel="canonical" href={canonicalUrl} />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="alternate" hreflang="gsw"   href={`https://buenzli.space/zh/`} />
    <link rel="alternate" hreflang="en-GB" href={`https://buenzli.space/en/`} />
    <link rel="alternate" hreflang="x-default" href="https://buenzli.space/zh/" />
    <meta property="og:title" content={t.metaTitle} />
    <meta property="og:description" content={t.metaDescription} />
    <meta property="og:url" content={canonicalUrl} />
    <meta property="og:type" content="website" />
    <meta property="og:site_name" content="bünzli.space" />
    <meta property="og:locale" content={lang === 'zh' ? 'gsw_CH' : 'en_GB'} />
    <meta property="og:image" content="https://buenzli.space/og-image.png" />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta property="og:image:alt" content={t.metaTitle} />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={t.metaTitle} />
    <meta name="twitter:description" content={t.metaDescription} />
    <meta name="twitter:image" content="https://buenzli.space/og-image.png" />
  </head>
  <body>
    <a href="#main-content" class="sr-only focus:not-sr-only focus:absolute focus:top-4 focus:left-4 bg-zurich-blue text-white px-4 py-2 rounded z-50">
      {t.navSkip}
    </a>

    <!-- Navigation -->
    <header id="site-header" class="fixed top-0 left-0 right-0 z-50 transition-all duration-300">
      <div class="max-w-6xl mx-auto px-4 sm:px-6 flex items-center justify-between h-14">

        <!-- Logo -->
        <a href={`/${lang}/`} class="flex items-center gap-2">
          <img src="/zh-lion.svg" alt="" aria-hidden="true" class="w-5 h-5 nav-lion" style="filter: brightness(0) saturate(100%)" />
          <span class="font-bold text-lg tracking-tight nav-wordmark">
            Bünzli<span class="nav-dot font-medium" style="color: var(--color-zurich-blue)">.Space</span>
          </span>
        </a>

        <!-- Desktop nav -->
        <nav class="hidden md:flex items-center gap-8" aria-label="Main navigation">
          {navLinks.map(({ label, href }) => (
            <a href={href} class="text-[13px] nav-link transition-colors">
              {label}
            </a>
          ))}
        </nav>

        <!-- Right controls -->
        <div class="flex items-center gap-3">
          <LanguageSwitcher currentLang={lang} />
          <span class="hidden sm:inline-block h-5 w-px bg-zurich-border" aria-hidden="true"></span>
          <button
            type="button"
            data-open-contact="beta"
            class="hidden sm:inline-flex items-center gap-1.5 px-3 py-1.5 rounded-md text-[13px] font-semibold bg-zurich-blue text-white hover:bg-zurich-blue-dark transition-colors duration-150 shadow-short"
          >
            {t.navBetaCta}
            <svg width="13" height="13" viewBox="0 0 13 13" fill="none" aria-hidden="true">
              <path d="M2.5 6.5h8M7 3.5l3 3-3 3" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
            </svg>
          </button>
          <!-- Mobile hamburger -->
          <button id="mobile-menu-btn" aria-label="Menu" class="md:hidden w-8 h-8 flex items-center justify-center nav-hamburger">
            <svg id="menu-icon-open" width="18" height="18" viewBox="0 0 18 18" fill="none">
              <path d="M2 4.5h14M2 9h14M2 13.5h14" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/>
            </svg>
            <svg id="menu-icon-close" class="hidden" width="18" height="18" viewBox="0 0 18 18" fill="none">
              <path d="M3 3l12 12M15 3L3 15" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/>
            </svg>
          </button>
        </div>
      </div>

    </header>

    <!-- Mobile menu (full-screen overlay) -->
    <div id="mobile-menu" class="hidden md:hidden fixed inset-0 z-[60] mobile-menu-bg flex-col">
      <div class="flex items-center justify-between h-14 px-4 sm:px-6 border-b border-zurich-border/60">
        <a href={`/${lang}/`} class="flex items-center gap-2">
          <img src="/zh-lion.svg" alt="" aria-hidden="true" class="w-5 h-5" style="filter: brightness(0) saturate(100%)" />
          <span class="font-bold text-lg tracking-tight text-zurich-dark">
            Bünzli<span class="font-medium" style="color: var(--color-zurich-blue)">.Space</span>
          </span>
        </a>
        <button id="mobile-menu-close" aria-label="Close menu" class="w-8 h-8 flex items-center justify-center text-zurich-dark">
          <svg width="18" height="18" viewBox="0 0 18 18" fill="none">
            <path d="M3 3l12 12M15 3L3 15" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/>
          </svg>
        </button>
      </div>
      <nav class="flex-1 overflow-y-auto px-4 sm:px-6 py-6" aria-label="Mobile navigation">
        {navLinks.map(({ label, href }) => (
          <a href={href} class="block py-4 text-lg font-medium nav-link transition-colors border-b border-zurich-border/40">
            {label}
          </a>
        ))}
        <button
          type="button"
          data-open-contact="beta"
          class="mt-8 flex items-center justify-center gap-1.5 px-4 py-3.5 rounded-md text-base font-semibold bg-zurich-blue text-white hover:bg-zurich-blue-dark transition-colors w-full"
        >
          {t.navBetaCta}
          <svg width="14" height="14" viewBox="0 0 14 14" fill="none" aria-hidden="true">
            <path d="M2.5 7h9M8 3.5l3.5 3.5L8 10.5" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
          </svg>
        </button>
      </nav>
    </div>

    <main id="main-content">
      <slot />
    </main>

    <!-- Footer -->
    <footer class="bg-zurich-blue text-white">
      <div class="max-w-6xl mx-auto px-4 sm:px-6 py-14 sm:py-20">
        <div class="grid grid-cols-2 sm:grid-cols-4 gap-8 mb-14">

          <!-- Brand -->
          <div class="col-span-2 sm:col-span-1">
            <div class="flex items-center gap-2 mb-3">
              <img src="/zh-lion.svg" alt="" aria-hidden="true" class="w-5 h-5 brightness-0 invert opacity-80" />
              <span class="font-bold text-lg text-white">bünzli<span class="text-white/60">.</span></span>
            </div>
            <p class="text-xs text-white/60 leading-relaxed">{t.footerTagline}</p>
          </div>

          <!-- Product -->
          <div>
            <h4 class="text-xs font-semibold text-white/50 uppercase tracking-wider mb-3">{t.footerProduct}</h4>
            <ul class="space-y-2">
              <li><a href="#board"   class="text-sm text-white/70 hover:text-white transition-colors">{t.navBoard}</a></li>
              <li><a href="#day"     class="text-sm text-white/70 hover:text-white transition-colors">{t.navDay}</a></li>
              <li><a href="#compare" class="text-sm text-white/70 hover:text-white transition-colors">{t.navCompare}</a></li>
              <li><a href="#privacy" class="text-sm text-white/70 hover:text-white transition-colors">{t.navPrivacy}</a></li>
            </ul>
          </div>

          <!-- Community -->
          <div>
            <h4 class="text-xs font-semibold text-white/50 uppercase tracking-wider mb-3">{t.footerCommunity}</h4>
            <ul class="space-y-2">
              <li><button type="button" data-open-contact="beta"   class="text-sm text-white/70 hover:text-white transition-colors text-left">{t.footerBeta}</button></li>
              <li><button type="button" data-open-contact="collab" class="text-sm text-white/70 hover:text-white transition-colors text-left">{t.footerCollaborate}</button></li>
              <li><a href="https://github.com/benedictvonhoffmann-zuri-droid/zueribot" target="_blank" rel="noopener noreferrer" class="text-sm text-white/70 hover:text-white transition-colors">{t.footerGitHub}</a></li>
            </ul>
          </div>

          <!-- Legal -->
          <div>
            <h4 class="text-xs font-semibold text-white/50 uppercase tracking-wider mb-3">{t.footerLegal}</h4>
            <ul class="space-y-2">
              <li><button type="button" data-open-legal="imprint" class="text-sm text-white/70 hover:text-white transition-colors text-left">{t.footerImpressum}</button></li>
              <li><button type="button" data-open-legal="privacy" class="text-sm text-white/70 hover:text-white transition-colors text-left">{t.footerDatenschutz}</button></li>
            </ul>
          </div>
        </div>

        <div class="border-t border-white/20 pt-8 flex flex-col sm:flex-row items-center justify-between gap-4">
          <p class="text-xs text-white/50 font-mono">{t.footerMade}</p>
          <p class="text-xs text-white/50">© 2026 bünzli.space</p>
        </div>
      </div>
    </footer>

    <ContactModal t={t} />

    <!-- Legal dialogs (single-page friendly) -->
    <dialog id="legal-imprint" class="legal-dialog">
      <div class="legal-dialog-inner">
        <div class="flex items-center justify-between mb-4">
          <h2 class="text-xl font-bold text-zurich-dark">{t.imprintTitle}</h2>
          <button type="button" data-close-legal aria-label={t.legalClose} class="w-8 h-8 rounded-full hover:bg-zh-black-5 flex items-center justify-center text-zurich-gray">
            <svg width="14" height="14" viewBox="0 0 14 14" fill="none"><path d="M3 3l8 8M11 3l-8 8" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/></svg>
          </button>
        </div>
        <div class="legal-prose" set:html={t.imprintBody}></div>
      </div>
    </dialog>

    <dialog id="legal-privacy" class="legal-dialog">
      <div class="legal-dialog-inner">
        <div class="flex items-center justify-between mb-4">
          <h2 class="text-xl font-bold text-zurich-dark">{t.privacyTitle}</h2>
          <button type="button" data-close-legal aria-label={t.legalClose} class="w-8 h-8 rounded-full hover:bg-zh-black-5 flex items-center justify-center text-zurich-gray">
            <svg width="14" height="14" viewBox="0 0 14 14" fill="none"><path d="M3 3l8 8M11 3l-8 8" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/></svg>
          </button>
        </div>
        <div class="legal-prose" set:html={t.privacyBody}></div>
      </div>
    </dialog>

    <script>
      const header = document.getElementById('site-header') as HTMLElement;
      const mobileMenuBtn = document.getElementById('mobile-menu-btn') as HTMLButtonElement;
      const mobileMenu = document.getElementById('mobile-menu') as HTMLElement;
      const iconOpen = document.getElementById('menu-icon-open') as HTMLElement;
      const iconClose = document.getElementById('menu-icon-close') as HTMLElement;

      // Sticky nav — always solid on light hero
      if (header) header.classList.add('nav-solid');
      function updateNav() {
        if (!header) return;
        header.classList.add(window.scrollY > 20 ? 'nav-scrolled' : 'nav-top');
        header.classList.remove(window.scrollY > 20 ? 'nav-top' : 'nav-scrolled');
      }
      updateNav();
      window.addEventListener('scroll', updateNav, { passive: true });

      // Mobile menu toggle (full-screen overlay)
      const mobileMenuCloseBtn = document.getElementById('mobile-menu-close') as HTMLButtonElement | null;

      function openMobileMenu() {
        mobileMenu.classList.remove('hidden');
        mobileMenu.classList.add('flex');
        iconOpen.classList.add('hidden');
        iconClose.classList.remove('hidden');
        document.body.classList.add('overflow-hidden');
      }
      function closeMobileMenu() {
        mobileMenu.classList.add('hidden');
        mobileMenu.classList.remove('flex');
        iconOpen.classList.remove('hidden');
        iconClose.classList.add('hidden');
        document.body.classList.remove('overflow-hidden');
      }

      mobileMenuBtn?.addEventListener('click', () => {
        if (mobileMenu.classList.contains('hidden')) openMobileMenu();
        else closeMobileMenu();
      });
      mobileMenuCloseBtn?.addEventListener('click', closeMobileMenu);

      // Close mobile menu on nav link click
      mobileMenu?.querySelectorAll('nav a').forEach(link => {
        link.addEventListener('click', closeMobileMenu);
      });

      // Scroll animations
      const observer = new IntersectionObserver(
        (entries) => {
          entries.forEach(entry => {
            if (entry.isIntersecting) {
              entry.target.classList.add('is-visible');
              observer.unobserve(entry.target);
            }
          });
        },
        { threshold: 0.1, rootMargin: '0px 0px -60px 0px' }
      );
      document.querySelectorAll('[data-animate], [data-animate-stagger]').forEach(el => observer.observe(el));

      // Legal dialogs
      document.querySelectorAll<HTMLButtonElement>('[data-open-legal]').forEach(btn => {
        btn.addEventListener('click', () => {
          const key = btn.dataset.openLegal;
          const dlg = document.getElementById(`legal-${key}`) as HTMLDialogElement | null;
          dlg?.showModal();
        });
      });
      document.querySelectorAll<HTMLButtonElement>('[data-close-legal]').forEach(btn => {
        btn.addEventListener('click', () => {
          const dlg = btn.closest('dialog') as HTMLDialogElement | null;
          dlg?.close();
        });
      });
      // Backdrop click closes dialog
      document.querySelectorAll<HTMLDialogElement>('dialog.legal-dialog').forEach(dlg => {
        dlg.addEventListener('click', (e) => {
          if (e.target === dlg) dlg.close();
        });
      });
    </script>

    <style is:global>
      /* Legal dialogs — global so set:html content gets styled */
      dialog.legal-dialog {
        max-width: 640px;
        width: calc(100% - 2rem);
        max-height: 85vh;
        border: 1px solid var(--color-zurich-border);
        border-radius: 6px;
        padding: 0;
        background: white;
        box-shadow: 0 24px 64px -16px rgba(0, 0, 0, 0.3);
        margin: auto;
        position: fixed;
        inset: 0;
      }
      dialog.legal-dialog::backdrop {
        background: rgba(0, 64, 124, 0.4);
        backdrop-filter: blur(4px);
      }
      .legal-dialog-inner {
        padding: 1.75rem 1.75rem 2rem;
        max-height: 85vh;
        overflow-y: auto;
      }
      .legal-prose p {
        font-size: 0.875rem;
        line-height: 1.65;
        color: var(--color-zurich-gray);
        margin: 0 0 0.9rem 0;
      }
      .legal-prose p:last-child { margin-bottom: 0; }
      .legal-prose a {
        color: var(--color-zurich-blue);
        text-decoration: underline;
        text-underline-offset: 2px;
      }
      .legal-prose a:hover { color: var(--color-zurich-blue-dark); }
      .legal-prose strong { color: var(--color-zurich-dark); font-weight: 600; }
    </style>

    <style>
      #site-header {
        background: rgba(255, 255, 255, 0.85);
        backdrop-filter: blur(16px);
        -webkit-backdrop-filter: blur(16px);
        border-bottom: 1px solid transparent;
        transition: background 200ms ease, border-color 200ms ease;
      }
      #site-header.nav-scrolled {
        background: rgba(255, 255, 255, 0.94);
        border-bottom-color: rgba(0, 0, 0, 0.06);
      }
      .nav-wordmark { color: var(--color-zurich-dark); }
      .nav-dot { color: var(--color-zurich-blue); }
      .nav-link { color: var(--color-zurich-gray); }
      .nav-link:hover { color: var(--color-zurich-dark); }
      .nav-hamburger svg path { stroke: var(--color-zurich-dark); }
      .mobile-menu-bg { background: rgba(255, 255, 255, 0.97); backdrop-filter: blur(16px); }
    </style>
  </body>
</html>
