---
import '../styles/global.css';
import LanguageSwitcher from '../components/LanguageSwitcher.astro';
import { LOCALE_META, type Locale } from '../i18n/locales';
import type { TranslationSchema } from '../i18n/translations/de';

interface Props {
  lang: Locale;
  t: TranslationSchema;
}

const { lang, t } = Astro.props;
const htmlLang = LOCALE_META[lang].htmlLang;
const canonicalUrl = `https://buenzli.space/${lang}/`;

const betaHref = `mailto:hello@buenzli.space?subject=${encodeURIComponent('Beta Test Request - buenzli.space')}&body=${encodeURIComponent('Hi Buenzli Team,\n\nI would like to beta test buenzli.space!\n\nLinkedIn profile: \nWhy I want to test: \nWhat I would use Bünzli AI for: \n\nBest regards')}`;
const collabHref = `mailto:hello@buenzli.space?subject=${encodeURIComponent('Collaboration Inquiry - buenzli.space')}&body=${encodeURIComponent('Hi Buenzli Team,\n\nI would like to collaborate on buenzli.space!\n\nLinkedIn profile: \nWhy I want to collaborate: \nSkills I bring: \n\nBest regards')}`;

const navLinks = [
  { label: t.navScenarios, href: '#scenarios' },
  { label: t.navHow,       href: '#how' },
  { label: t.navPrivacy,   href: '#privacy' },
  { label: t.navCommunity, href: '#community' },
];
---

<!doctype html>
<html lang={htmlLang} class="scroll-smooth">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{t.metaTitle}</title>
    <meta name="description" content={t.metaDescription} />
    <link rel="canonical" href={canonicalUrl} />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="alternate" hreflang="gsw"   href={`https://buenzli.space/zh/`} />
    <link rel="alternate" hreflang="en-GB" href={`https://buenzli.space/en/`} />
    <link rel="alternate" hreflang="x-default" href="https://buenzli.space/zh/" />
    <meta property="og:title" content={t.metaTitle} />
    <meta property="og:description" content={t.metaDescription} />
    <meta property="og:url" content={canonicalUrl} />
    <meta property="og:type" content="website" />
  </head>
  <body>
    <a href="#main-content" class="sr-only focus:not-sr-only focus:absolute focus:top-4 focus:left-4 bg-zurich-blue text-white px-4 py-2 rounded z-50">
      {t.navSkip}
    </a>

    <!-- Navigation -->
    <header id="site-header" class="fixed top-0 left-0 right-0 z-50 transition-all duration-300">
      <div class="max-w-6xl mx-auto px-4 sm:px-6 flex items-center justify-between h-14">

        <!-- Logo -->
        <a href={`/${lang}/`} class="flex items-center gap-2">
          <img src="/zh-lion.svg" alt="" aria-hidden="true" class="w-5 h-5 opacity-90 nav-lion" />
          <span class="font-bold text-lg tracking-tight nav-wordmark">
            bünzli<span class="nav-dot">.</span>
          </span>
        </a>

        <!-- Desktop nav -->
        <nav class="hidden md:flex items-center gap-8" aria-label="Main navigation">
          {navLinks.map(({ label, href }) => (
            <a href={href} class="text-[13px] nav-link transition-colors">
              {label}
            </a>
          ))}
        </nav>

        <!-- Right controls -->
        <div class="flex items-center gap-2">
          <LanguageSwitcher currentLang={lang} />
          <a
            href={betaHref}
            class="hidden sm:inline-flex items-center gap-1.5 px-3 py-1.5 rounded-lg text-xs font-semibold bg-zurich-blue text-white hover:bg-zurich-blue-dark transition-colors duration-150"
          >
            {t.navBetaCta}
            <svg width="12" height="12" viewBox="0 0 12 12" fill="none" aria-hidden="true">
              <path d="M2 6h8M7 3l3 3-3 3" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
            </svg>
          </a>
          <!-- Mobile hamburger -->
          <button id="mobile-menu-btn" aria-label="Menu" class="md:hidden w-8 h-8 flex items-center justify-center nav-hamburger">
            <svg id="menu-icon-open" width="18" height="18" viewBox="0 0 18 18" fill="none">
              <path d="M2 4.5h14M2 9h14M2 13.5h14" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/>
            </svg>
            <svg id="menu-icon-close" class="hidden" width="18" height="18" viewBox="0 0 18 18" fill="none">
              <path d="M3 3l12 12M15 3L3 15" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/>
            </svg>
          </button>
        </div>
      </div>

      <!-- Mobile menu -->
      <div id="mobile-menu" class="hidden md:hidden border-b px-4 pb-4 mobile-menu-bg">
        {navLinks.map(({ label, href }) => (
          <a href={href} class="block py-2.5 text-sm nav-link transition-colors border-b border-white/10 last:border-0">
            {label}
          </a>
        ))}
        <a
          href={betaHref}
          class="mt-3 flex items-center justify-center gap-1.5 px-4 py-2.5 rounded-lg text-sm font-semibold bg-zurich-blue text-white"
        >
          {t.navBetaCta}
        </a>
      </div>
    </header>

    <main id="main-content">
      <slot />
    </main>

    <!-- Footer -->
    <footer class="bg-zurich-blue text-white">
      <div class="max-w-6xl mx-auto px-4 sm:px-6 py-14 sm:py-20">
        <div class="grid grid-cols-2 sm:grid-cols-4 gap-8 mb-14">

          <!-- Brand -->
          <div class="col-span-2 sm:col-span-1">
            <div class="flex items-center gap-2 mb-3">
              <img src="/zh-lion.svg" alt="" aria-hidden="true" class="w-5 h-5 brightness-0 invert opacity-80" />
              <span class="font-bold text-lg text-white">bünzli<span class="text-white/60">.</span></span>
            </div>
            <p class="text-xs text-white/60 leading-relaxed">{t.footerTagline}</p>
          </div>

          <!-- Product -->
          <div>
            <h4 class="text-xs font-semibold text-white/50 uppercase tracking-wider mb-3">{t.footerProduct}</h4>
            <ul class="space-y-2">
              <li><a href="#scenarios" class="text-sm text-white/70 hover:text-white transition-colors">{t.navScenarios}</a></li>
              <li><a href="#how"       class="text-sm text-white/70 hover:text-white transition-colors">{t.navHow}</a></li>
              <li><a href="#privacy"   class="text-sm text-white/70 hover:text-white transition-colors">{t.navPrivacy}</a></li>
            </ul>
          </div>

          <!-- Community -->
          <div>
            <h4 class="text-xs font-semibold text-white/50 uppercase tracking-wider mb-3">{t.footerCommunity}</h4>
            <ul class="space-y-2">
              <li><a href={betaHref}    class="text-sm text-white/70 hover:text-white transition-colors">{t.footerBeta}</a></li>
              <li><a href={collabHref}  class="text-sm text-white/70 hover:text-white transition-colors">{t.footerCollaborate}</a></li>
              <li><a href="https://github.com" target="_blank" rel="noopener noreferrer" class="text-sm text-white/70 hover:text-white transition-colors">{t.footerGitHub}</a></li>
            </ul>
          </div>

          <!-- Legal -->
          <div>
            <h4 class="text-xs font-semibold text-white/50 uppercase tracking-wider mb-3">{t.footerLegal}</h4>
            <ul class="space-y-2">
              <li><a href="#" class="text-sm text-white/70 hover:text-white transition-colors">{t.footerImpressum}</a></li>
              <li><a href="#" class="text-sm text-white/70 hover:text-white transition-colors">{t.footerDatenschutz}</a></li>
            </ul>
          </div>
        </div>

        <div class="border-t border-white/20 pt-8 flex flex-col sm:flex-row items-center justify-between gap-4">
          <p class="text-xs text-white/50 font-mono">{t.footerMade}</p>
          <p class="text-xs text-white/50">© 2026 bünzli.space</p>
        </div>
      </div>
    </footer>

    <script>
      const header = document.getElementById('site-header') as HTMLElement;
      const mobileMenuBtn = document.getElementById('mobile-menu-btn') as HTMLButtonElement;
      const mobileMenu = document.getElementById('mobile-menu') as HTMLElement;
      const iconOpen = document.getElementById('menu-icon-open') as HTMLElement;
      const iconClose = document.getElementById('menu-icon-close') as HTMLElement;

      // Sticky nav
      function updateNav() {
        if (!header) return;
        if (window.scrollY > 20) {
          header.classList.add('nav-solid');
          header.classList.remove('nav-transparent');
        } else {
          header.classList.add('nav-transparent');
          header.classList.remove('nav-solid');
        }
      }
      updateNav();
      window.addEventListener('scroll', updateNav, { passive: true });

      // Mobile menu toggle
      mobileMenuBtn?.addEventListener('click', () => {
        const isOpen = !mobileMenu.classList.contains('hidden');
        mobileMenu.classList.toggle('hidden', isOpen);
        iconOpen.classList.toggle('hidden', !isOpen);
        iconClose.classList.toggle('hidden', isOpen);
      });

      // Close mobile menu on nav link click
      mobileMenu?.querySelectorAll('a').forEach(link => {
        link.addEventListener('click', () => {
          mobileMenu.classList.add('hidden');
          iconOpen.classList.remove('hidden');
          iconClose.classList.add('hidden');
        });
      });

      // Scroll animations
      const observer = new IntersectionObserver(
        (entries) => {
          entries.forEach(entry => {
            if (entry.isIntersecting) {
              entry.target.classList.add('is-visible');
              observer.unobserve(entry.target);
            }
          });
        },
        { threshold: 0.1, rootMargin: '0px 0px -60px 0px' }
      );
      document.querySelectorAll('[data-animate], [data-animate-stagger]').forEach(el => observer.observe(el));
    </script>

    <style>
      .nav-transparent {
        background: transparent;
        border-bottom: 1px solid transparent;
      }
      .nav-solid {
        background: rgba(255, 255, 255, 0.92);
        backdrop-filter: blur(16px);
        -webkit-backdrop-filter: blur(16px);
        border-bottom: 1px solid rgba(0, 0, 0, 0.06);
      }

      /* Lion icon color */
      .nav-transparent .nav-lion { filter: brightness(0) invert(1); }
      .nav-solid .nav-lion { filter: none; }
      #site-header:not(.nav-solid):not(.nav-transparent) .nav-lion { filter: brightness(0) invert(1); }

      /* Wordmark color */
      .nav-transparent .nav-wordmark { color: white; }
      .nav-solid .nav-wordmark { color: var(--color-zurich-dark); }
      #site-header:not(.nav-solid):not(.nav-transparent) .nav-wordmark { color: white; }

      .nav-transparent .nav-dot { color: rgba(255,255,255,0.6); }
      .nav-solid .nav-dot { color: var(--color-zurich-blue); }
      #site-header:not(.nav-solid):not(.nav-transparent) .nav-dot { color: rgba(255,255,255,0.6); }

      /* Nav links */
      .nav-transparent .nav-link { color: rgba(255,255,255,0.7); }
      .nav-transparent .nav-link:hover { color: white; }
      .nav-solid .nav-link { color: var(--color-zurich-gray); }
      .nav-solid .nav-link:hover { color: var(--color-zurich-dark); }
      #site-header:not(.nav-solid):not(.nav-transparent) .nav-link { color: rgba(255,255,255,0.7); }

      /* Hamburger icon */
      .nav-transparent .nav-hamburger svg path { stroke: white; }
      .nav-solid .nav-hamburger svg path { stroke: var(--color-zurich-dark); }
      #site-header:not(.nav-solid):not(.nav-transparent) .nav-hamburger svg path { stroke: white; }

      /* Mobile menu background */
      .nav-transparent .mobile-menu-bg { background: rgba(8,17,31,0.95); backdrop-filter: blur(16px); }
      .nav-solid .mobile-menu-bg { background: rgba(255,255,255,0.96); backdrop-filter: blur(16px); }
      #site-header:not(.nav-solid):not(.nav-transparent) .mobile-menu-bg { background: rgba(8,17,31,0.95); }
    </style>
  </body>
</html>
