# Multi-stage: build the Astro landing site, then serve with nginx.

FROM node:25-alpine AS build
WORKDIR /app/frontend/landing

COPY frontend/landing/package.json frontend/landing/package-lock.json* ./
RUN npm ci

COPY frontend/landing/ ./
RUN npm run build


FROM nginx:alpine
COPY --from=build /app/frontend/landing/dist /usr/share/nginx/html
COPY deploy/pods/app/nginx.conf /etc/nginx/nginx.conf
EXPOSE 80
